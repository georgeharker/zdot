#!/usr/bin/env zsh
# Refresh MCP servers configuration from 1Password
# Requires _ZDOT_OP_ACTIVE=1 (service account configured)

function refresh_mcpservers_secret {
    [[ $_ZDOT_OP_ACTIVE -ne 1 ]] && return 1

    local secrets_src_dir secrets_cache secrets_mcp_dir
    _mcp_get_secrets_mcp_dirs

    # Get op config
    local -a op_config
    local op_config_dir
    op_config_dir=$(op_get_config_dir)
    op_config=("${(@f)$(op_get_config_args)}")

    if [[ ! -f "${secrets_src_dir}/mcpservers.json" ]]; then
        return 0
    fi

    if op ${op_config} inject --force --in-file "${secrets_src_dir}/mcpservers.json" --out-file "${secrets_cache}/${USER}.mcpservers.json" > /dev/null; then
        return 0
    else
        echo "Failed to refresh MCP servers configuration"
        return 1
    fi
}
