#!/usr/bin/env zsh
# Refresh MCP servers configuration from 1Password
# Requires _ZDOT_OP_ACTIVE=1 (service account configured)

function create_gcert_secrets {
    [[ $_ZDOT_OP_ACTIVE -ne 1 ]] && return 1
    
    function _auth_google_account() {
        local account=$1
        local secretname=$2
        local domain="${${account#*@}%%.*}"
        local certfile="${domain}-google-cert.json"
        local gmail_mcp_dir="${secrets_mcp_dir}/gmail-mcp"
        local domain_mcp_dir="${gmail_mcp_dir}/${domain}"
        local certfile_out="${domain_mcp_dir}/credentials.json"
        local certfile_dest="${domain_mcp_dir}/${certfile}"

        local _find_free_port() {
python3 <<EOF
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind(('', 0))
port = s.getsockname()[1]
s.close()
print(port)
EOF
        }
        local port=$(_find_free_port)
        echo "authenticating for account ${account}"

        [[ -d "${domain_mcp_dir}" ]] || mkdir -p "${domain_mcp_dir}"
        [[ -f "${certfile_dest}" ]] && rm "${certfile_dest}"

        # Link in the cert
        [[ -f "${domain_mcp_dir}/gcp-oauth.keys.json" ]] && rm "${domain_mcp_dir}/gcp-oauth.keys.json"
        ln -s "${gmail_mcp_dir}/gcp-oauth.keys.json" "${domain_mcp_dir}/gcp-oauth.keys.json"
        
        # Auth in the gmail-mcp dir
        env MCP_CONFIG_DIR="${domain_mcp_dir}" \
            AUTH_SERVER_PORT=$port \
            npx @shinzolabs/gmail-mcp auth 2>&1 > /dev/null
        
        mv "${certfile_out}" "${certfile_dest}"
        op_upsert_file "API" "${secretname}" "${certfile_dest}"
    }

    local secrets_src_dir secrets_cache secrets_mcp_dir
    _mcp_get_secrets_mcp_dirs

    op_get_gmail_certs
    local -A gmail_certs=("${reply[@]}")
        
    op_setup_gcert_certificate

    for account secretname in ${(kv)gmail_certs}; do
        echo "Setting up ${account} with item ${secretname}"
        _auth_google_account "${account}" "${secretname}"
    done

    # Get op config downloaded
    refresh_gcert_secrets
}
