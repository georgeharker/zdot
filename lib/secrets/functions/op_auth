#!/usr/bin/env zsh
# Authenticate with 1Password (interactive only)
# Sets up op configuration and ensures user is signed in
# Returns 0 on success, 1 on failure or user cancellation

function op_auth {
    # Only run in interactive shells
    if [[ $_ZDOT_IS_INTERACTIVE -ne 1 ]]; then
        return 1
    fi

    # Get op config
    local -a op_config
    local op_config_dir
    op_config_dir=$(op_get_config_dir)
    op_config=("${(@f)$(op_get_config_args)}")

    # Check if no_op flag is set
    if [[ -f "${op_config_dir}/no_op" ]]; then
        return 1
    fi

    # If config doesn't exist, prompt to set up
    if [[ ! -f "${op_config_dir}/config" ]]; then
        printf "Set up 1Password? [Y/n/c] "
        read -r -k 1 option
        [[ "$option" = $'\n' ]] || echo
        case "$option" in
            [yY$'\n']) ;;
            [nN])
                mkdir -p "${op_config_dir}"
                touch "${op_config_dir}/no_op"
                return 1
                ;;
            *)
                echo "You will be asked at next login"
                return 1
                ;;
        esac
    fi

    # Ensure user is signed in
    if ! op whoami ${op_config} &> /dev/null; then
        echo "Sign into 1Password"
        eval $(op ${op_config} signin) || return 1
    fi

    return 0
}
