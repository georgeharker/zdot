#!/usr/bin/env zsh
# zdot: Top-level CLI dispatcher for zdot management commands
# Usage: zdot <noun> <verb> [options...]
#
# Nouns and verbs:
#   cache   status | invalidate | compile
#   hook    list [--verbose|-v] [--all|-a] [--ordered|-o] | plan
#   phase   list [--context <ctx>]
#   plugin  list [--loaded|--installed|--declared] | update [spec] | clean [--dry-run] [--remove-unused] | reclone
#   module  list | clone <name>
#   completion refresh
#   secret  refresh
#   info
#   debug
#   bench
#   profile
#   help    [noun]

function zdot() {
    local noun="${1:-}"
    local verb="${2:-}"

    # ── per-noun help blocks ─────────────────────────────────────────────────

    function _zdot_help_cache() {
        zdot_info "zdot cache — cache management"
        zdot_info ""
        zdot_info "  zdot cache status      Show cache stats and hit/miss counts"
        zdot_info "  zdot cache invalidate  Invalidate all cached files"
        zdot_info "  zdot cache compile     Recompile all autoloaded function files"
    }

    function _zdot_help_hook() {
        zdot_info "zdot hook — hook and execution plan management"
        zdot_info ""
        zdot_info "  zdot hook list [-v] [-a] [-o]  List registered hooks"
        zdot_info "    -v, --verbose            Show full hook metadata"
        zdot_info "    -a, --all                Include unexecuted hooks"
        zdot_info "    -o, --ordered            Show hooks in execution-plan order"
        zdot_info "  zdot hook plan            Print the full execution plan"
        zdot_info "  zdot hook status          Show per-hook run status from last startup"
    }

    function _zdot_help_plugin() {
        zdot_info "zdot plugin — plugin management"
        zdot_info ""
        zdot_info "  zdot plugin list [--loaded|--installed|--declared]"
        zdot_info "                          List plugins (default: all declared)"
        zdot_info "  zdot plugin update [spec]  Update one or all plugins"
        zdot_info "  zdot plugin clean [--dry-run] [--remove-unused]"
        zdot_info "                          Remove stale plugin directories"
        zdot_info "  zdot plugin reclone     Delete and re-clone all plugins"
    }

    function _zdot_help_module() {
        zdot_info "zdot module — module management"
        zdot_info ""
        zdot_info "  zdot module list           List all loaded modules and their source directory"
        zdot_info "  zdot module clone <name>   Copy a module to the first user directory in the search path"
    }

    function _zdot_help_completion() {
        zdot_info "zdot completion — shell completion management"
        zdot_info ""
        zdot_info "  zdot completion refresh  Regenerate completion files for registered tools"
    }

    function _zdot_help_secret() {
        zdot_info "zdot secret — secret management"
        zdot_info ""
        zdot_info "  zdot secret refresh  Pull latest secrets from 1Password into the shell"
    }

    function _zdot_help_info() {
        zdot_info "zdot info — show zdot environment and runtime state"
        zdot_info ""
        zdot_info "  Prints key paths, shell context flags, cache config, and counts"
        zdot_info "  for plugins, hooks, and modules."
    }

    function _zdot_help_debug() {
        zdot_info "zdot debug — dump full internal state"
        zdot_info ""
        zdot_info "  Prints the execution plan, executed hooks, provided/promised phases,"
        zdot_info "  plugin load status, and loaded modules."
    }

    function _zdot_help_bench() {
        zdot_info "zdot bench — measure zsh startup time across all four shell contexts"
        zdot_info ""
        zdot_info "  Usage: zdot bench [--compare] [ITERATIONS]"
        zdot_info ""
        zdot_info "  Times startup for: interactive non-login, interactive login,"
        zdot_info "  non-interactive non-login, non-interactive login."
        zdot_info ""
        zdot_info "  --compare   A/B mode: run each context twice with ZDOT_OLD_SETUP=true"
        zdot_info "              and ZDOT_OLD_SETUP=false.  Requires your dotfiles to honour"
        zdot_info "              ZDOT_OLD_SETUP.  See 'docs/COMMANDS.md' for details."
        zdot_info "  ITERATIONS  Number of timed runs per variant (default: 20)."
    }

    function _zdot_help_profile() {
        zdot_info "zdot profile — profile zsh startup with zprof to find slow functions"
        zdot_info ""
        zdot_info "  Usage: zdot profile [--warm]"
        zdot_info ""
        zdot_info "  Wraps your shell in a zprof instrumentation layer and prints a"
        zdot_info "  function-level timing breakdown.  Use bench for total wall-clock"
        zdot_info "  timing; use profile to diagnose what to optimise."
        zdot_info ""
        zdot_info "  --warm   Symlink existing compdump files so compinit is skipped."
        zdot_info ""
        zdot_info "  To compare setups, set ZDOT_OLD_SETUP before running:"
        zdot_info "    ZDOT_OLD_SETUP=true  zdot profile"
        zdot_info "    ZDOT_OLD_SETUP=false zdot profile"
    }

    function _zdot_help_update() {
        zdot_info "zdot update — self-update management"
        zdot_info ""
        zdot_info "  zdot update check-updates [--force]  Check for available updates"
        zdot_info "  zdot update apply         [--force]  Fetch and apply updates now"
        zdot_info ""
        zdot_info "  --force  Bypass frequency check and run immediately"
        zdot_info ""
        zdot_info "  Update mode and behaviour are controlled via zstyle:"
        zdot_info "    zstyle ':zdot:update' mode  disabled|reminder|prompt|auto"
        zdot_info "    zstyle ':zdot:update' in-tree-commit  none|prompt|auto"
        zdot_info "    zstyle ':zdot:update' link-tree  true|false"
    }

    function _zdot_help_phase() {
        zdot_info "zdot phase — phase and tool phase inspection"
        zdot_info ""
        zdot_info "  zdot phase list [--context <ctx>]  List all registered phases"
        zdot_info "    --context <ctx>                  Filter to hooks in the given context"
    }

    function _zdot_help_help() {
        zdot_info "zdot help — show help"
        zdot_info ""
        zdot_info "  zdot help           Show the top-level noun list"
        zdot_info "  zdot help <noun>    Show detailed help for a noun"
        zdot_info ""
        zdot_info "  Available nouns: cache hook phase plugin module completion secret update info debug bench profile help"
    }

    function _zdot_usage() {
        zdot_info "Usage: zdot <noun> <verb> [options]"
        zdot_info ""
        zdot_info "  cache      status | invalidate | compile"
        zdot_info "  hook       list [-v] [-a] [-o] | plan | status"
        zdot_info "  phase      list [--context <ctx>]"
        zdot_info "  plugin     list [--loaded|--installed|--declared] | update [spec] | clean [--dry-run] [--remove-unused] | reclone"
        zdot_info "  module     list | clone <name>"
        zdot_info "  update     check-updates [--force] | apply [--force]"
        zdot_info "  completion refresh"
        zdot_info "  secret     refresh"
        zdot_info "  info"
        zdot_info "  debug"
        zdot_info "  bench"
        zdot_info "  profile"
        zdot_info "  help       [noun]"
        zdot_info ""
        zdot_info "Run 'zdot help <noun>' for detailed help on any noun."
    }

    # ── dispatch ─────────────────────────────────────────────────────────────

    case "$noun" in

        # ── cache ─────────────────────────────────────────────────────────
        cache)
            case "$verb" in
                status)   zdot_cache_stats ;;
                invalidate) zdot_cache_invalidate ;;
                compile)  zdot_cache_compile_all ;;
                help|--help|-h) _zdot_help_cache ;;
                *)
                    zdot_error "zdot cache: unknown verb '${verb}'"
                    zdot_info "  verbs: status | invalidate | compile"
                    return 1
                    ;;
            esac
            ;;

        # ── hook ──────────────────────────────────────────────────────────
        hook)
            case "$verb" in
                list)   zdot_hooks_list "${@:3}" ;;
                plan)   zdot_show_plan ;;
                status) zdot_hooks_status ;;
                help|--help|-h) _zdot_help_hook ;;
                *)
                    zdot_error "zdot hook: unknown verb '${verb}'"
                    zdot_info "  verbs: list | plan | status"
                    return 1
                    ;;
            esac
            ;;

        # ── phase ─────────────────────────────────────────────────────────
        phase)
            case "$verb" in
                list) zdot_phases_list "${@:3}" ;;
                help|--help|-h) _zdot_help_phase ;;
                *)
                    zdot_error "zdot phase: unknown verb '${verb}'"
                    zdot_info "  verbs: list"
                    return 1
                    ;;
            esac
            ;;

        # ── plugin ────────────────────────────────────────────────────────
        plugin)
            case "$verb" in
                list)    zdot_list_plugins "${@:3}" ;;
                update)  zdot_update_plugin "${@:3}" ;;
                clean)   zdot_clean_plugins "${@:3}" ;;
                reclone) zdot_reclone_plugins ;;
                help|--help|-h) _zdot_help_plugin ;;
                *)
                    zdot_error "zdot plugin: unknown verb '${verb}'"
                    zdot_info "  verbs: list | update [spec] | clean | reclone"
                    return 1
                    ;;
            esac
            ;;

        # ── module ────────────────────────────────────────────────────────
        module)
            case "$verb" in
                list)       zdot_module_list ;;
                clone)
                    local name="${3:-}"
                    if [[ -z "$name" ]]; then
                        zdot_error "zdot module clone: module name required"
                        zdot_info "  usage: zdot module clone <module-name>"
                        return 1
                    fi
                    # Resolve the source directory: prefer already-loaded provenance,
                    # then search the path, then fall back to lib/.
                    local src_dir=""
                    if [[ -n "${_ZDOT_MODULE_SOURCE_DIR[$name]:-}" ]]; then
                        src_dir="${_ZDOT_MODULE_SOURCE_DIR[$name]}"
                    else
                        _zdot_build_module_search_path
                        local _sp_dir
                        for _sp_dir in "${_ZDOT_MODULE_SEARCH_PATH[@]}"; do
                            if [[ -d "${_sp_dir}/${name}" ]]; then
                                src_dir="${_sp_dir}/${name}"
                                break
                            fi
                        done
                    fi
                    if [[ -z "$src_dir" || ! -d "$src_dir" ]]; then
                        zdot_error "zdot module clone: module not found: $name"
                        return 1
                    fi
                    # Destination: first non-lib entry in the search path.
                    _zdot_build_module_search_path
                    local dest_root=""
                    local _sp_entry
                    for _sp_entry in "${_ZDOT_MODULE_SEARCH_PATH[@]}"; do
                        if [[ "$_sp_entry" != "${_ZDOT_LIB_DIR}" ]]; then
                            dest_root="$_sp_entry"
                            break
                        fi
                    done
                    if [[ -z "$dest_root" ]]; then
                        zdot_error "zdot module clone: no user directory configured in search path"
                        zdot_info "  Set one via: zstyle ':zdot:modules' search-path <dir>"
                        return 1
                    fi
                    local dest_dir="${dest_root}/${name}"
                    if [[ -d "$dest_dir" ]]; then
                        zdot_error "zdot module clone: destination already exists: $dest_dir"
                        return 1
                    fi
                    if ! cp -r "$src_dir" "$dest_dir"; then
                        zdot_error "zdot module clone: failed to copy module"
                        return 1
                    fi
                    zdot_info "Cloned module '${name}' to: ${dest_dir}"
                    ;;
                help|--help|-h) _zdot_help_module ;;
                *)
                    zdot_error "zdot module: unknown verb '${verb}'"
                    zdot_info "  verbs: list | clone <name>"
                    return 1
                    ;;
            esac
            ;;

        # ── completion ────────────────────────────────────────────────────
        completion)
            case "$verb" in
                refresh) refresh_completions ;;
                help|--help|-h) _zdot_help_completion ;;
                *)
                    zdot_error "zdot completion: unknown verb '${verb}'"
                    zdot_info "  verbs: refresh"
                    return 1
                    ;;
            esac
            ;;

        # ── secret ────────────────────────────────────────────────────────
        secret)
            case "$verb" in
                refresh) refresh_shell_secrets ;;
                help|--help|-h) _zdot_help_secret ;;
                *)
                    zdot_error "zdot secret: unknown verb '${verb}'"
                    zdot_info "  verbs: refresh"
                    return 1
                    ;;
            esac
            ;;

        # ── update ────────────────────────────────────────────────────────
        update)
            local _force=""
            [[ "${3:-}" == "--force" ]] && _force="--force"
            case "$verb" in
                check-updates)
                    if (( ! ${+functions[_zdot_update_handle_update]} )); then
                        zdot_error "zdot update: update hook not loaded (zstyle ':zdot:update' mode disabled?)"
                        return 1
                    fi
                    # Bypass frequency check: remove timestamp so the epoch
                    # test always passes, then call handle_update normally.
                    local _ts="${XDG_CACHE_HOME:-$HOME/.cache}/zdot/zdot_update"
                    if [[ -n "$_force" && -f "$_ts" ]]; then
                        command rm -f "$_ts"
                    fi
                    _zdot_update_handle_update
                    ;;
                apply)
                    if (( ! ${+functions[_zdot_update_handle_update]} )); then
                        zdot_error "zdot update: update hook not loaded (zstyle ':zdot:update' mode disabled?)"
                        return 1
                    fi
                    local _ts="${XDG_CACHE_HOME:-$HOME/.cache}/zdot/zdot_update"
                    [[ -n "$_force" && -f "$_ts" ]] && command rm -f "$_ts"
                    # Force auto mode for this invocation only
                    local _saved_mode
                    zstyle -s ':zdot:update' mode _saved_mode
                    zstyle ':zdot:update' mode auto
                    _zdot_update_handle_update
                    zstyle ':zdot:update' mode "${_saved_mode:-disabled}"
                    ;;
                help|--help|-h) _zdot_help_update ;;
                *)
                    zdot_error "zdot update: unknown verb '${verb}'"
                    zdot_info "  verbs: check-updates [--force] | apply [--force]"
                    return 1
                    ;;
            esac
            ;;

        # ── info ──────────────────────────────────────────────────────────
        info)
            zdot_report "zdot info"
            zdot_info ""
            zdot_info "Paths:"
            zdot_info "  base:  ${ZDOT_DIR:-<unset>}"
            zdot_info "  lib:   ${_ZDOT_LIB_DIR:-<unset>}"
            zdot_info "  cache: ${_ZDOT_CACHE_DIR:-<unset>}"
            zdot_info ""
            zdot_info "Shell context:"
            zdot_info "  interactive: ${_ZDOT_IS_INTERACTIVE:-<unset>}"
            zdot_info "  login:       ${_ZDOT_IS_LOGIN:-<unset>}"
            zdot_info ""
            zdot_info "Cache:"
            zdot_info "  enabled: ${_ZDOT_CACHE_ENABLED:-<unset>}"
            zdot_info "  version: ${_ZDOT_CACHE_VERSION:-<unset>}"
            zdot_info ""
            zdot_info "Counts:"
            zdot_info "  plugins declared: ${#_ZDOT_PLUGINS_ORDER}"
            zdot_info "  plugins loaded:   ${#_ZDOT_PLUGINS_LOADED}"
            zdot_info "  hooks registered: ${#_ZDOT_HOOKS}"
             zdot_info "  hooks executed:   ${#_ZDOT_HOOKS_EXEC_RESULT}"
            zdot_info "  modules loaded:   ${#_ZDOT_MODULES_LOADED}"
            ;;

        # ── debug ─────────────────────────────────────────────────────────
        debug)
            zdot_report "zdot debug — global state"
            zdot_info ""

            zdot_info "--- _ZDOT_EXECUTION_PLAN (${#_ZDOT_EXECUTION_PLAN} entries) ---"
            local i=1
            local id
            for id in $_ZDOT_EXECUTION_PLAN; do
                zdot_info "  $i. $id -> ${_ZDOT_HOOKS[$id]:-?}"
                (( i++ ))
            done

            zdot_info ""
            zdot_info "--- _ZDOT_HOOKS_EXEC_RESULT (${#_ZDOT_HOOKS_EXEC_RESULT} entries) ---"
            for id in "${(k)_ZDOT_HOOKS_EXEC_RESULT[@]}"; do
                zdot_info "  $id -> ${_ZDOT_HOOKS_EXEC_RESULT[$id]}"
            done

            zdot_info ""
            zdot_info "--- _ZDOT_PHASES_PROVIDED ---"
            zdot_info "  ${(j: :)${(k)_ZDOT_PHASES_PROVIDED[@]:-<none>}}"

            zdot_info ""
            zdot_info "--- _ZDOT_PLUGINS_ORDER (${#_ZDOT_PLUGINS_ORDER} entries) ---"
            local spec
            for spec in $_ZDOT_PLUGINS_ORDER; do
                local loaded="${_ZDOT_PLUGINS_LOADED[$spec]:+yes}"
                zdot_info "  ${loaded:-no }  $spec"
            done

            zdot_info ""
            zdot_info "--- _ZDOT_MODULES_LOADED (${#_ZDOT_MODULES_LOADED} entries) ---"
            local mod
            for mod in "${(k)_ZDOT_MODULES_LOADED[@]}"; do
                zdot_info "  $mod"
            done
            ;;

        # ── bench ─────────────────────────────────────────────────────────
        bench)
            local bench_script="${ZDOT_DIR}/scripts/benchmark.zsh"
            if [[ ! -f "$bench_script" ]]; then
                zdot_error "zdot bench: benchmark script not found: $bench_script"
                return 1
            fi
            zsh "$bench_script" "${@:2}"
            ;;

        # ── profile ───────────────────────────────────────────────────────
        profile)
            local profile_script="${ZDOT_DIR}/scripts/profile.zsh"
            if [[ ! -f "$profile_script" ]]; then
                zdot_error "zdot profile: profile script not found: $profile_script"
                return 1
            fi
            zsh "$profile_script" "${@:2}"
            ;;

        # ── help ──────────────────────────────────────────────────────────
        help)
            case "$verb" in
                cache)      _zdot_help_cache ;;
                hook)       _zdot_help_hook ;;
                phase)      _zdot_help_phase ;;
                plugin)     _zdot_help_plugin ;;
                module)     _zdot_help_module ;;
                completion) _zdot_help_completion ;;
                secret)     _zdot_help_secret ;;
                info)       _zdot_help_info ;;
                debug)      _zdot_help_debug ;;
                bench)      _zdot_help_bench ;;
                profile)    _zdot_help_profile ;;
                help)       _zdot_help_help ;;
                "")         _zdot_usage ;;
                *)
                    zdot_error "zdot help: unknown noun '${verb}'"
                    zdot_info "  nouns: cache hook phase plugin module completion secret update info debug bench profile help"

                    return 1
                    ;;
            esac
            ;;

        # ── fallthrough ───────────────────────────────────────────────────
        ""|--help|-h)
            _zdot_usage
            ;;
        *)
            zdot_error "zdot: unknown noun '${noun}'"
            _zdot_usage
            return 1
            ;;
    esac
}
