#!/usr/bin/env zsh
# List all registered hooks organized by the phases they provide
# Usage: zdot_hooks_list [--verbose|-v] [--all|-a|all] [--ordered|-o]
# Options:
#   --verbose, -v    Show whether functions are defined and show dependencies
#   --all, -a, all   Show all contexts (default: only show current shell context)
#   --ordered, -o    Show hooks in execution-plan order (eager → deferred → unplanned)

function zdot_hooks_list() {
    local verbose=0
    local show_all=0
    local ordered=0

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --verbose|-v)
                verbose=1
                ;;
            --all|-a|all)
                show_all=1
                ;;
            --ordered|-o)
                ordered=1
                ;;
        esac
    done

    # --ordered mode: show hooks in execution-plan order (mirrors zdot_show_hooks)
    if [[ $ordered -eq 1 ]]; then
        zdot_report "Registered hooks (execution order):"
        zdot_info ""

        local -A _shown
        local _pos=1

        # Eager execution plan
        if (( ${#_ZDOT_EXECUTION_PLAN[@]} > 0 )); then
            for hook_id in "${_ZDOT_EXECUTION_PLAN[@]}"; do
                local func="${_ZDOT_HOOKS[$hook_id]}"
                local name="${_ZDOT_HOOK_NAMES[$hook_id]:-$func}"
                local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]:-(none)}"
                local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "  [$_pos] $func$_status_mark"
                zdot_info "       name:     $name"
                zdot_info "       provides: $provides"
                zdot_info "       deferred: no"
                if [[ $verbose -eq 1 ]]; then
                    local ctx="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
                    local req="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
                    zdot_info "       contexts: $ctx"
                    zdot_info "       requires: $req"
                fi
                local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
                local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                [[ -n $_grp  ]] && zdot_info "       group:         $_grp"
                [[ -n $_rgrp ]] && zdot_info "       requires-group: $_rgrp"
                [[ -n $_pgrp ]] && zdot_info "       provides-group: $_pgrp"
                zdot_info ""
                _shown[$hook_id]=1
                (( _pos++ ))
            done
        fi

        # Deferred execution plan
        if (( ${#_ZDOT_EXECUTION_PLAN_DEFERRED[@]} > 0 )); then
            for hook_id in "${_ZDOT_EXECUTION_PLAN_DEFERRED[@]}"; do
                local func="${_ZDOT_HOOKS[$hook_id]}"
                local name="${_ZDOT_HOOK_NAMES[$hook_id]:-$func}"
                local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]:-(none)}"
                local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "  [$_pos] $func$_status_mark"
                zdot_info "       name:     $name"
                zdot_info "       provides: $provides"
                zdot_info "       deferred: yes"
                if [[ ${_ZDOT_HOOK_DEFER_ARGS[$hook_id]+set} == set ]]; then
                    local _flag_key="${_ZDOT_HOOK_DEFER_ARGS[$hook_id]}"
                    zdot_info "       defer-args: ${_ZDOT_DEFER_FLAG_NAMES[$_flag_key]:-$_flag_key}"
                fi
                if [[ $verbose -eq 1 ]]; then
                    local ctx="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
                    local req="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
                    zdot_info "       contexts: $ctx"
                    zdot_info "       requires: $req"
                fi
                local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
                local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                [[ -n $_grp  ]] && zdot_info "       group:         $_grp"
                [[ -n $_rgrp ]] && zdot_info "       requires-group: $_rgrp"
                [[ -n $_pgrp ]] && zdot_info "       provides-group: $_pgrp"
                zdot_info ""
                _shown[$hook_id]=1
                (( _pos++ ))
            done
        fi

        # Finally-group hooks (run after all deferred hooks drain)
        local _finally_shown=0
        for hook_id in ${=_ZDOT_GROUP_MEMBERS[finally]:-}; do
            [[ -n "${_shown[$hook_id]}" ]] && continue
            if (( _finally_shown == 0 )); then
                zdot_info "  Finally (run after all deferred hooks complete):"
                zdot_info ""
                _finally_shown=1
            fi
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local name="${_ZDOT_HOOK_NAMES[$hook_id]:-$func}"
            local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]:-(none)}"
            local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
            _zdot_hook_display_marks "$hook_id" "$func"
            zdot_info "  [$_pos] $func$_status_mark [finally]"
            zdot_info "       name:     $name"
            zdot_info "       provides: $provides"
            zdot_info "       group:    finally"
            if [[ $verbose -eq 1 ]]; then
                local ctx="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
                local req="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
                zdot_info "       contexts: $ctx"
                zdot_info "       requires: $req"
            fi
            zdot_info ""
            _shown[$hook_id]=1
            (( _pos++ ))
        done

        # Truly unplanned hooks (registered but not in any plan or finally group)
        local _unplanned=0
        for hook_id in ${(k)_ZDOT_HOOKS}; do
            [[ -n "${_shown[$hook_id]}" ]] && continue
            if (( _unplanned == 0 )); then
                zdot_info "  Unplanned (not in execution plan — context mismatch or zdot_init not called):"
                zdot_info ""
                _unplanned=1
            fi
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local name="${_ZDOT_HOOK_NAMES[$hook_id]:-$func}"
            local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]:-(none)}"
            local is_deferred="no"
            [[ -n "${_ZDOT_DEFERRED_HOOKS[$hook_id]}" ]] && is_deferred="yes"
            zdot_info "  [?] $func"
            zdot_info "       name:     $name"
            zdot_info "       provides: $provides"
            zdot_info "       deferred: $is_deferred"
            if [[ $verbose -eq 1 ]]; then
                local ctx="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
                local req="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
                zdot_info "       contexts: $ctx"
                zdot_info "       requires: $req"
            fi
            local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
            local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
            local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
            [[ -n $_grp  ]] && zdot_info "       group:         $_grp"
            [[ -n $_rgrp ]] && zdot_info "       requires-group: $_rgrp"
            [[ -n $_pgrp ]] && zdot_info "       provides-group: $_pgrp"
            zdot_info ""
        done

        local _total=${#_ZDOT_HOOKS[@]}
        zdot_info "Total: $_total hook(s) registered"
        return 0
    fi

    zdot_info "Registered Hooks:"
    zdot_info ""

    # Show current shell context
    local interactive_ctx="noninteractive"
    [[ $_ZDOT_IS_INTERACTIVE -eq 1 ]] && interactive_ctx="interactive"
    local login_ctx="nonlogin"
    [[ $_ZDOT_IS_LOGIN -eq 1 ]] && login_ctx="login"
    local variant_display="${_ZDOT_VARIANT:-}"
    local variant_line="Active context: ${interactive_ctx}, ${login_ctx}"
    [[ -n "$variant_display" ]] && variant_line+="  variant: ${variant_display}"
    zdot_info "$variant_line"

    if [[ $show_all -eq 1 ]]; then
        zdot_info "Showing: all contexts"
    else
        zdot_info "Showing: active contexts only (use --all to see all)"
    fi
    zdot_info ""

    # Determine which contexts to show
    local -a contexts_to_show
    if [[ $show_all -eq 1 ]]; then
        contexts_to_show=(interactive noninteractive login nonlogin)
    else
        contexts_to_show=("$interactive_ctx" "$login_ctx")
    fi

    # Build a set of hook_ids that appear in either execution plan
    local -A _in_plan=()
    local _pid
    for _pid in "${_ZDOT_EXECUTION_PLAN[@]}" "${_ZDOT_EXECUTION_PLAN_DEFERRED[@]}"; do
        _in_plan[$_pid]=1
    done

    # Build a set of hook_ids in the finally group
    local -A _in_finally=()
    local _fid
    for _fid in ${=_ZDOT_GROUP_MEMBERS[finally]:-}; do
        _in_finally[$_fid]=1
    done

    # Group hooks by the phase they provide
    local -A phases_to_hooks=()
    local -a leaf_hooks=()       # in plan, ran, but provide no phase
    local -a finally_hooks=()    # --group finally (run after all deferred hooks drain)
    local -a unplanned_hooks=()  # registered but not in any plan
    local -a error_hooks=()

    for hook_id in ${(k)_ZDOT_HOOKS}; do
        local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
        local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]}"

        # Check if this hook matches any of the contexts we want to show
        local matches_context=0
        if [[ $show_all -eq 1 ]]; then
            matches_context=1
        else
            for ctx in ${=contexts}; do
                if [[ " ${contexts_to_show[@]} " =~ " ${ctx} " ]]; then
                    matches_context=1
                    break
                fi
            done
        fi

        if [[ $matches_context -eq 1 ]]; then
            if [[ -n "$provides" ]]; then
                # Hook provides one or more phases (space-separated)
                for phase in ${=provides}; do
                    if [[ -z "${phases_to_hooks[$phase]}" ]]; then
                        phases_to_hooks[$phase]="$hook_id"
                    else
                        phases_to_hooks[$phase]="${phases_to_hooks[$phase]} $hook_id"
                    fi
                done
            elif [[ -n "${_in_finally[$hook_id]}" ]]; then
                # Hook in the finally group (runs after all deferred hooks drain)
                finally_hooks+=("$hook_id")
            elif [[ -n "${_in_plan[$hook_id]}" ]]; then
                # Hook is in the execution plan but provides no phase (leaf hook)
                leaf_hooks+=("$hook_id")
            else
                # Hook without a provided phase — check for unsatisfiable requirements
                local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]}"
                local has_error=0

                for required_phase in ${=requires}; do
                    # Phase is satisfiable if at least one hook provides it in the
                    # hook's declared contexts.
                    if ! _zdot_has_provider_in_contexts "$required_phase" ${=contexts}; then
                        has_error=1
                        break
                    fi
                done

                if [[ $has_error -eq 1 ]]; then
                    error_hooks+=("$hook_id")
                else
                    unplanned_hooks+=("$hook_id")
                fi
            fi
        fi
    done

    # Display hooks organized by phase
    if [[ ${#phases_to_hooks[@]} -gt 0 ]]; then
        zdot_info "Hooks by Phase:"
        zdot_info ""

        # Sort phase names for consistent output
        local -a sorted_phases=("${(@ko)phases_to_hooks}")

        for phase in "${sorted_phases[@]}"; do
            zdot_info "Phase: $phase"
            local hook_ids="${phases_to_hooks[$phase]}"

            for hook_id in ${=hook_ids}; do
                local func="${_ZDOT_HOOKS[$hook_id]}"
                local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
                local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
                local optional="${_ZDOT_HOOK_OPTIONAL[$hook_id]}"

                if [[ $verbose -eq 1 ]]; then
                    # Verbose mode: show if function is defined and dependencies
                    if typeset -f "$func" > /dev/null 2>&1; then
                        zdot_info "  ✓ $func (defined)"
                    else
                        zdot_info "  ✗ $func (NOT defined)"
                    fi
                    zdot_info "    name: ${_ZDOT_HOOK_NAMES[$hook_id]:-$func}"
                    zdot_info "    contexts: $contexts"
                    zdot_info "    requires: $requires"
                    local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
                    local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                    local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                    [[ -n $_grp  ]] && zdot_info "    group:          $_grp"
                    [[ -n $_rgrp ]] && zdot_info "    requires-group: $_rgrp"
                    [[ -n $_pgrp ]] && zdot_info "    provides-group: $_pgrp"
                    local _vr="${_ZDOT_HOOK_VARIANTS[$hook_id]:-}"
                    local _ve="${_ZDOT_HOOK_VARIANT_EXCLUDES[$hook_id]:-}"
                    [[ -n $_vr ]] && zdot_info "    variant:         $_vr"
                    [[ -n $_ve ]] && zdot_info "    variant-exclude: $_ve"
                    if [[ "$optional" == 1 ]]; then
                        zdot_info "    optional: yes"
                    fi
                    local _deferred="${_ZDOT_DEFERRED_HOOKS[(Ie)$hook_id]}"
                    if [[ "$_deferred" -gt 0 ]]; then
                        zdot_info "    deferred: yes"
                        if [[ ${_ZDOT_HOOK_DEFER_ARGS[$hook_id]+set} == set ]]; then
                            local _flag_key="${_ZDOT_HOOK_DEFER_ARGS[$hook_id]}"
                            zdot_info "    defer-args: ${_ZDOT_DEFER_FLAG_NAMES[$_flag_key]:-$_flag_key}"
                        fi
                    fi
                else
                    # Normal mode: just list the hook
                    local optional_mark=""
                    [[ "$optional" == 1 ]] && optional_mark=" [optional]"
                    local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                    _zdot_hook_display_marks "$hook_id" "$func"
                    local _variant_mark=""
                    local _vr="${_ZDOT_HOOK_VARIANTS[$hook_id]:-}"
                    local _ve="${_ZDOT_HOOK_VARIANT_EXCLUDES[$hook_id]:-}"
                    [[ -n $_vr ]] && _variant_mark=" [variant: $_vr]"
                    [[ -n $_ve ]] && _variant_mark=" [variant-excl: $_ve]"
                    zdot_info "  • $func ($contexts)$optional_mark$_name_mark$_deferred_mark$_noquiet_mark$_status_mark$_variant_mark"
                fi
            done
            zdot_info ""
        done
    fi

    # Display leaf hooks (in execution plan, ran, but provide no phase)
    if [[ ${#leaf_hooks[@]} -gt 0 ]]; then
        zdot_info "Leaf Hooks (no phase provided):"
        zdot_info ""

        for hook_id in "${leaf_hooks[@]}"; do
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
            local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
            local optional="${_ZDOT_HOOK_OPTIONAL[$hook_id]}"

            if [[ $verbose -eq 1 ]]; then
                if typeset -f "$func" > /dev/null 2>&1; then
                    zdot_info "  ✓ $func (defined)"
                else
                    zdot_info "  ✗ $func (NOT defined)"
                fi
                zdot_info "    contexts: $contexts"
                zdot_info "    requires: $requires"
                local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
                local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                [[ -n $_grp  ]] && zdot_info "    group:          $_grp"
                [[ -n $_rgrp ]] && zdot_info "    requires-group: $_rgrp"
                [[ -n $_pgrp ]] && zdot_info "    provides-group: $_pgrp"
                if [[ "$optional" == 1 ]]; then
                    zdot_info "    optional: yes"
                fi
                local _deferred_lf="${_ZDOT_DEFERRED_HOOKS[(Ie)$hook_id]}"
                if [[ "$_deferred_lf" -gt 0 ]]; then
                    zdot_info "    deferred: yes"
                    if [[ ${_ZDOT_HOOK_DEFER_ARGS[$hook_id]+set} == set ]]; then
                        local _flag_key="${_ZDOT_HOOK_DEFER_ARGS[$hook_id]}"
                        zdot_info "    defer-args: ${_ZDOT_DEFER_FLAG_NAMES[$_flag_key]:-$_flag_key}"
                    fi
                fi
            else
                local optional_mark=""
                [[ "$optional" == 1 ]] && optional_mark=" [optional]"
                local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "  • $func ($contexts)$optional_mark$_name_mark$_deferred_mark$_noquiet_mark$_status_mark"
            fi
        done
        zdot_info ""
    fi

    # Display finally-group hooks (run after all deferred hooks drain)
    if [[ ${#finally_hooks[@]} -gt 0 ]]; then
        zdot_info "Finally Hooks (run after all deferred hooks complete):"
        zdot_info ""

        for hook_id in "${finally_hooks[@]}"; do
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
            local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
            local optional="${_ZDOT_HOOK_OPTIONAL[$hook_id]}"

            if [[ $verbose -eq 1 ]]; then
                if typeset -f "$func" > /dev/null 2>&1; then
                    zdot_info "  ✓ $func (defined)"
                else
                    zdot_info "  ✗ $func (NOT defined)"
                fi
                zdot_info "    contexts: $contexts"
                zdot_info "    requires: $requires"
                zdot_info "    group: finally"
                local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                [[ -n $_rgrp ]] && zdot_info "    requires-group: $_rgrp"
                [[ -n $_pgrp ]] && zdot_info "    provides-group: $_pgrp"
                if [[ "$optional" == 1 ]]; then
                    zdot_info "    optional: yes"
                fi
            else
                local optional_mark=""
                [[ "$optional" == 1 ]] && optional_mark=" [optional]"
                local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "  • $func ($contexts)$optional_mark$_name_mark$_noquiet_mark$_status_mark [finally]"
            fi
        done
        zdot_info ""
    fi

    # Display truly unplanned hooks (registered but not in any plan or finally group)
    if [[ ${#unplanned_hooks[@]} -gt 0 ]]; then
        zdot_info "Unplanned Hooks:"
        zdot_info ""

        for hook_id in "${unplanned_hooks[@]}"; do
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
            local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
            local optional="${_ZDOT_HOOK_OPTIONAL[$hook_id]}"

            if [[ $verbose -eq 1 ]]; then
                if typeset -f "$func" > /dev/null 2>&1; then
                    zdot_info "  ✓ $func (defined)"
                else
                    zdot_info "  ✗ $func (NOT defined)"
                fi
                zdot_info "    contexts: $contexts"
                zdot_info "    requires: $requires"
                local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
                local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
                local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
                [[ -n $_grp  ]] && zdot_info "    group:          $_grp"
                [[ -n $_rgrp ]] && zdot_info "    requires-group: $_rgrp"
                [[ -n $_pgrp ]] && zdot_info "    provides-group: $_pgrp"
                if [[ "$optional" == 1 ]]; then
                    zdot_info "    optional: yes"
                fi
                local _deferred_up="${_ZDOT_DEFERRED_HOOKS[(Ie)$hook_id]}"
                if [[ "$_deferred_up" -gt 0 ]]; then
                    zdot_info "    deferred: yes"
                    if [[ ${_ZDOT_HOOK_DEFER_ARGS[$hook_id]+set} == set ]]; then
                        local _flag_key="${_ZDOT_HOOK_DEFER_ARGS[$hook_id]}"
                        zdot_info "    defer-args: ${_ZDOT_DEFER_FLAG_NAMES[$_flag_key]:-$_flag_key}"
                    fi
                fi
            else
                local optional_mark=""
                [[ "$optional" == 1 ]] && optional_mark=" [optional]"
                local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "  • $func ($contexts)$optional_mark$_name_mark$_deferred_mark$_noquiet_mark$_status_mark"
            fi
        done
        zdot_info ""
    fi

    # Display hooks with errors (unsatisfiable requirements)
    if [[ ${#error_hooks[@]} -gt 0 ]]; then
        zdot_warn "⚠️  Hooks with Missing Requirements:"
        zdot_info ""

        for hook_id in "${error_hooks[@]}"; do
            local func="${_ZDOT_HOOKS[$hook_id]}"
            local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"
            local requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-none}"
            local optional="${_ZDOT_HOOK_OPTIONAL[$hook_id]}"

            zdot_warn "  ✗ $func ($contexts)"
            zdot_info "    requires: $requires"
            local _grp="${_ZDOT_HOOK_GROUP[$hook_id]:-}"
            local _rgrp="${_ZDOT_HOOK_REQUIRES_GROUP[$hook_id]:-}"
            local _pgrp="${_ZDOT_HOOK_PROVIDES_GROUP[$hook_id]:-}"
            [[ -n $_grp  ]] && zdot_info "    group:          $_grp"
            [[ -n $_rgrp ]] && zdot_info "    requires-group: $_rgrp"
            [[ -n $_pgrp ]] && zdot_info "    provides-group: $_pgrp"
            
            # Show which requirements are unsatisfiable
            for required_phase in ${=requires}; do
                if ! _zdot_has_provider_in_contexts "$required_phase" ${=contexts}; then
                    zdot_error "      ⚠ '$required_phase' is not provided by any hook"
                fi
            done
            
            if [[ "$optional" == 1 ]]; then
                zdot_info "    optional: yes"
            fi
        done
        zdot_info ""
    fi

    # Defer Order Constraints
    _zdot_defer_order_display

    zdot_info "Run 'zdot_show_defer_queue' to see deferred task submission order."
    zdot_info ""

    # Summary
    local total_hooks=${#_ZDOT_HOOKS[@]}
    local shown_hooks=0
    for phase in "${(@k)phases_to_hooks}"; do
        shown_hooks=$(( shown_hooks + ${#${=phases_to_hooks[$phase]}[@]} ))
    done
    shown_hooks=$(( shown_hooks + ${#leaf_hooks[@]} + ${#finally_hooks[@]} + ${#unplanned_hooks[@]} ))

    if [[ $show_all -eq 1 ]]; then
        zdot_info "Total: $total_hooks registered hook(s)"
    else
        zdot_info "Total: $shown_hooks hook(s) in active contexts (of $total_hooks registered)"
    fi
}
