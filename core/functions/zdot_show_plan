#!/usr/bin/env zsh
# Show the dependency-resolved execution plan for hooks
# Usage: zdot_show_plan

function zdot_show_plan() {
    if [[ ${#_ZDOT_EXECUTION_PLAN} -eq 0 ]]; then
        zdot_error "No execution plan built yet. Call zdot_build_execution_plan first."
        return 1
    fi

    zdot_report "Execution Plan (${#_ZDOT_EXECUTION_PLAN} hooks):"
    zdot_info ""

    # Show active context including variant
    local interactive_ctx="noninteractive"
    [[ $_ZDOT_IS_INTERACTIVE -eq 1 ]] && interactive_ctx="interactive"
    local login_ctx="nonlogin"
    [[ $_ZDOT_IS_LOGIN -eq 1 ]] && login_ctx="login"
    local _variant_info="${_ZDOT_VARIANT:-}"
    local _ctx_line="Active context: ${interactive_ctx}, ${login_ctx}"
    [[ -n "$_variant_info" ]] && _ctx_line+="  variant: ${_variant_info}"
    zdot_info "$_ctx_line"
    zdot_info ""

    local i=1
    for hook_id in $_ZDOT_EXECUTION_PLAN; do
        local func=${_ZDOT_HOOKS[$hook_id]}
        local _raw_provides="${_ZDOT_HOOK_PROVIDES[$hook_id]:-}"
        local _raw_requires="${_ZDOT_HOOK_REQUIRES[$hook_id]:-}"
        local provides=$(_zdot_render_phase_list "$_raw_provides")
        local requires=$(_zdot_render_phase_list "$_raw_requires")
        # Structural (not name-based) special case: a group BEGIN barrier — one that
        # provides _group_begin_<G> — whose requires are member tokens of that same
        # group <G> is a "gather everything before the group starts" barrier. Today
        # only finally/pre-defer do this (to sort last), but any group could; keying
        # off the shape keeps it general. Collapsing to [group:<G>] would be
        # misleading (it waits on every hook, not <G>'s own members), so label it.
        if [[ $_raw_provides == *_group_begin_* ]]; then
            local _bg=${${_raw_provides##*_group_begin_}%% *}
            [[ " $_raw_requires " == *" _group_member_${_bg}_"* ]] \
                && requires="%F{magenta}[after: every other hook]%f"
        fi
        local contexts=${_ZDOT_HOOK_CONTEXTS[$hook_id]}

        zdot_info "$i. $func"
        zdot_info "   contexts: $contexts"
        zdot_info "   provides: $provides"
        zdot_info "   requires: $requires"
        local _vr="${_ZDOT_HOOK_VARIANTS[$hook_id]:-}"
        local _ve="${_ZDOT_HOOK_VARIANT_EXCLUDES[$hook_id]:-}"
        [[ -n $_vr ]] && zdot_info "   variant:         $_vr"
        [[ -n $_ve ]] && zdot_info "   variant-exclude: $_ve"
        zdot_info ""
        (( i++ ))
    done
}
