#!/usr/bin/env zsh
# List all phases organised by provider
# Usage: zdot_phases_list [--context <ctx>]
# Options:
#   --context <ctx>  Show only hooks matching the given context

function zdot_phases_list() {
    local filter_ctx=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --context)
                shift
                filter_ctx="$1"
                ;;
        esac
        shift
    done

    zdot_info "Phases:"
    zdot_info ""

    # ── build phase → hook_id mapping ──────────────────────────────────────
    # Separate regular phases from tool: phases
    local -A regular_phases=()   # phase → "hook_id [hook_id ...]"
    local -A tool_phases=()      # phase → "hook_id [hook_id ...]"

    for hook_id in ${(k)_ZDOT_HOOKS}; do
        local provides="${_ZDOT_HOOK_PROVIDES[$hook_id]}"
        local contexts="${_ZDOT_HOOK_CONTEXTS[$hook_id]}"

        # Apply optional context filter
        if [[ -n "$filter_ctx" ]]; then
            local matches=0
            for ctx in ${=contexts}; do
                if [[ "$ctx" == "$filter_ctx" ]]; then
                    matches=1
                    break
                fi
            done
            [[ $matches -eq 0 ]] && continue
        fi

        for phase in ${=provides}; do
            if [[ "$phase" == tool:* ]]; then
                if [[ -z "${tool_phases[$phase]}" ]]; then
                    tool_phases[$phase]="$hook_id"
                else
                    tool_phases[$phase]="${tool_phases[$phase]} $hook_id"
                fi
            else
                if [[ -z "${regular_phases[$phase]}" ]]; then
                    regular_phases[$phase]="$hook_id"
                else
                    regular_phases[$phase]="${regular_phases[$phase]} $hook_id"
                fi
            fi
        done
    done

    # ── regular phases ──────────────────────────────────────────────────────
    if [[ ${#regular_phases[@]} -gt 0 ]]; then
        zdot_info "Regular Phases:"
        zdot_info ""

        local -a sorted=("${(@ko)regular_phases}")
        for phase in "${sorted[@]}"; do
            local hook_ids="${regular_phases[$phase]}"
            local -a id_list=(${=hook_ids})
            local conflict=""
            if [[ ${#id_list[@]} -gt 1 ]]; then
                # Only flag a real conflict if two providers share a context.
                # Providers in mutually exclusive contexts (e.g. interactive vs
                # noninteractive) are never both active — no conflict.
                local -A _seen_ctx=()
                local _real_conflict=0
                for _hid in "${id_list[@]}"; do
                    for _ctx in ${=_ZDOT_HOOK_CONTEXTS[$_hid]}; do
                        if [[ -n "${_seen_ctx[$_ctx]}" ]]; then
                            _real_conflict=1
                            break 2
                        fi
                        _seen_ctx[$_ctx]=1
                    done
                done
                [[ $_real_conflict -eq 1 ]] && conflict=" [conflict]"
            fi

            # Check if any hook providing this phase submitted deferred work
            local defer_mark=""
            _zdot_ran_deferred_mark "${id_list[@]}"

            zdot_info "  ${phase}${conflict}${defer_mark}"

            for hook_id in "${id_list[@]}"; do
                local func="${_ZDOT_HOOKS[$hook_id]}"
                local on_demand="${_ZDOT_HOOK_ON_DEMAND[$hook_id]}"
                local on_demand_mark=""
                [[ "$on_demand" -eq 1 ]] && on_demand_mark=" [on-demand]"
                local _name_mark="" _deferred_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "    • $func${on_demand_mark}${_name_mark}${_deferred_mark}"
            done
        done
        zdot_info ""
    else
        zdot_info "  (no regular phases registered)"
        zdot_info ""
    fi

    # ── tool phases ─────────────────────────────────────────────────────────
    if [[ ${#tool_phases[@]} -gt 0 ]]; then
        zdot_info "Tool Phases:"
        zdot_info ""

        local -a sorted_tools=("${(@ko)tool_phases}")
        for phase in "${sorted_tools[@]}"; do
            local hook_ids="${tool_phases[$phase]}"
            local -a id_list=(${=hook_ids})
            # tool: phases: first-registered wins; extras are silently skipped
            # (warn already emitted at registration time)
            local tool_name="${phase#tool:}"
            local available=""
            command -v "$tool_name" > /dev/null 2>&1 && available=" [available]"

            # Check if any hook providing this phase submitted deferred work
            local defer_mark=""
            _zdot_ran_deferred_mark "${id_list[@]}"

            zdot_info "  ${phase}${available}${defer_mark}"

            for hook_id in "${id_list[@]}"; do
                local func="${_ZDOT_HOOKS[$hook_id]}"
                local on_demand="${_ZDOT_HOOK_ON_DEMAND[$hook_id]}"
                local on_demand_mark=""
                [[ "$on_demand" -eq 1 ]] && on_demand_mark=" [on-demand]"
                local _name_mark="" _deferred_mark=""
                _zdot_hook_display_marks "$hook_id" "$func"
                zdot_info "    • $func${on_demand_mark}${_name_mark}${_deferred_mark}"
            done
        done
        zdot_info ""
    else
        zdot_info "  (no tool phases registered)"
        zdot_info ""
    fi

    # Defer Order Constraints
    _zdot_defer_order_display

    zdot_info "Run 'zdot_show_defer_queue' to see deferred task submission order."
    zdot_info ""

    # ── summary ─────────────────────────────────────────────────────────────
    local total=$(( ${#regular_phases[@]} + ${#tool_phases[@]} ))
    zdot_info "Total: ${#regular_phases[@]} regular phase(s), ${#tool_phases[@]} tool phase(s), $total phase(s) total"
}
