#compdef zdot

function _zdot() {
    local -a nouns
    nouns=(
        'cache:cache management (status, invalidate, compile)'
        'hook:hook and execution-plan management (list, plan, status, defer-queue)'
        'phase:phase and tool phase inspection (list)'
        'plugin:plugin management (list, update, clean, reclone)'
        'module:module management (list, clone)'
        'completion:shell completion management (refresh)'
        'secret:secret management (refresh)'
        'update:self-update management (check-updates, apply)'
        'info:show zdot environment and runtime state'
        'debug:dump full internal state'
        'bench:run shell startup benchmark'
        'profile:run shell startup profiler'
        'help:show help (optionally for a noun)'
    )

    # ── verbs per noun ───────────────────────────────────────────────────────

    local -a verbs_cache verbs_hook verbs_phase verbs_plugin verbs_module \
             verbs_completion verbs_secret verbs_update verbs_help

    verbs_cache=(
        'status:show cache stats and hit/miss counts'
        'invalidate:invalidate all cached files'
        'compile:recompile all autoloaded function files'
        'help:show help for cache'
    )

    verbs_hook=(
        'list:list registered hooks'
        'plan:print the full execution plan'
        'status:show per-hook run status from last startup'
        'defer-queue:show deferred task submission order'
        'help:show help for hook'
    )

    verbs_phase=(
        'list:list all registered phases'
        'help:show help for phase'
    )

    verbs_plugin=(
        'list:list plugins'
        'update:update one or all plugins'
        'clean:remove stale plugin directories'
        'reclone:delete and re-clone all plugins'
        'help:show help for plugin'
    )

    verbs_module=(
        'list:list all loaded modules and their source directory'
        'clone:copy a module to the first user directory in the search path'
        'help:show help for module'
    )

    verbs_completion=(
        'refresh:regenerate completion files for registered tools'
        'help:show help for completion'
    )

    verbs_secret=(
        'refresh:pull latest secrets from 1Password into the shell'
        'help:show help for secret'
    )

    verbs_update=(
        'check-updates:check for available updates'
        'apply:fetch and apply updates now'
        'help:show help for update'
    )

    verbs_help=(
        'cache:show help for cache'
        'hook:show help for hook'
        'phase:show help for phase'
        'plugin:show help for plugin'
        'module:show help for module'
        'completion:show help for completion'
        'secret:show help for secret'
        'update:show help for update'
        'info:show help for info'
        'debug:show help for debug'
        'bench:show help for bench'
        'profile:show help for profile'
        'help:show help for help'
    )

    # ── flags per noun+verb ──────────────────────────────────────────────────

    local -a flags_hook_list flags_plugin_list flags_plugin_clean \
             flags_update_check flags_update_apply flags_phase_list

    flags_hook_list=(
        '-v[show full hook metadata]'
        '--verbose[show full hook metadata]'
        '-a[show all contexts]'
        '--all[show all contexts]'
        '-o[show hooks in execution-plan order]'
        '--ordered[show hooks in execution-plan order]'
    )

    flags_plugin_list=(
        '--loaded[show only loaded plugins]'
        '--installed[show only installed plugins]'
        '--declared[show only declared plugins]'
    )

    flags_plugin_clean=(
        '--dry-run[show what would be removed without deleting]'
        '--remove-unused[also remove plugins not declared anywhere]'
    )

    flags_update=(
        '--force[bypass frequency check and run immediately]'
    )

    flags_phase_list=(
        '--context[filter to phases in the given context]:context:'
    )

    # ── dispatch on word position ────────────────────────────────────────────

    local noun="${words[2]}"
    local verb="${words[3]}"
    local cur_word="$CURRENT"

    case "$cur_word" in

        # ── completing noun (word 2) ─────────────────────────────────────────
        2)
            _describe -t nouns 'zdot noun' nouns
            ;;

        # ── completing verb (word 3) ─────────────────────────────────────────
        3)
            case "$noun" in
                cache)      _describe -t verbs 'cache verb' verbs_cache ;;
                hook)       _describe -t verbs 'hook verb' verbs_hook ;;
                phase)      _describe -t verbs 'phase verb' verbs_phase ;;
                plugin)     _describe -t verbs 'plugin verb' verbs_plugin ;;
                module)     _describe -t verbs 'module verb' verbs_module ;;
                completion) _describe -t verbs 'completion verb' verbs_completion ;;
                secret)     _describe -t verbs 'secret verb' verbs_secret ;;
                update)     _describe -t verbs 'update verb' verbs_update ;;
                help)       _describe -t nouns 'noun' verbs_help ;;
                *)          ;;
            esac
            ;;

        # ── completing flags (word 4+) ───────────────────────────────────────
        *)
            case "${noun}:${verb}" in
                hook:list)              _arguments -s "${flags_hook_list[@]}" ;;
                phase:list)             _arguments -s "${flags_phase_list[@]}" ;;
                plugin:list)            _arguments -s "${flags_plugin_list[@]}" ;;
                plugin:clean)           _arguments -s "${flags_plugin_clean[@]}" ;;
                update:check-updates)   _arguments -s "${flags_update[@]}" ;;
                update:apply)           _arguments -s "${flags_update[@]}" ;;
                module:clone)
                    # Offer all modules visible in the search path as clone candidates
                    _zdot_build_module_search_path
                    local -a all_modules
                    local _sp
                    for _sp in "${_ZDOT_MODULE_SEARCH_PATH[@]}"; do
                        all_modules+=( ${_sp}/*(N/:t) )
                    done
                    all_modules=( ${(u)all_modules} )   # deduplicate
                    _describe -t modules 'module' all_modules
                    ;;
                *)                      ;;
            esac
            ;;

    esac
}