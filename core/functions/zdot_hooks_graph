#!/usr/bin/env zsh
# Show a pstree-style dependency-tree graph for the zdot hook system.
#
# Usage:
#   zdot_hooks_graph --depends <name>      Tree of what <name> requires
#   zdot_hooks_graph --uses    <name>      Tree of what depends on <name>
#   zdot_hooks_graph --all                 Full graph (roots have no dependents)
#
# Layout options:
#   --ascii              Use ASCII glyphs (|-, `-, |) instead of Unicode box-drawing
#   --max-depth N        Cap recursion depth (default: unlimited)
#   --show-internal      Show synthetic group-begin / group-end scaffolding hooks
#   -v, --verbose        Show "label  <func>" instead of just the user-facing label
#
# Output style:
#   - Siblings sorted by display name (hard edges first, then soft)
#   - DAG nodes printed once; repeat occurrences shown as "name ↑"
#   - Single-child chains collapse onto one line:  A ─── B ─── C
#   - Multiple children laid out pstree-style with parent-width alignment:
#         parent─┬─child1        (hard --requires edge: solid connector)
#                ├─child2
#                ╰◂child3        (soft --after  edge: dim, arrow ◂ = runs after)
#                ╰▸child4        (soft --before edge: dim, arrow ▸ = runs before)
#   - Soft (--after / --before) edges are dimmed with a direction arrow and are
#     never inlined, so they read distinctly from hard dependencies.
#
# Glyph widths are measured from the terminal (cursor-position report) so the
# column math stays aligned even for double-width Nerd-Font icon glyphs.

function zdot_hooks_graph() {

    # ── argument parsing ──────────────────────────────────────────────────────

    local mode="" target_name=""
    local _g_ascii=0 _g_max_depth=-1 _g_show_internal=0 _g_verbose=0
    # Group rendering: 0 = expand each group inline at first use (default);
    # 1 = keep groups as atoms in the main tree and list their members in a
    # "Group contents" section afterwards.
    local _g_groups_after=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --depends)        mode="depends"; target_name="$2"; shift 2 ;;
            --uses)           mode="uses";    target_name="$2"; shift 2 ;;
            --all)            mode="all";     shift ;;
            --ascii)          _g_ascii=1;     shift ;;
            --max-depth)      _g_max_depth="$2"; shift 2 ;;
            --show-internal)  _g_show_internal=1; shift ;;
            --groups-inline)  _g_groups_after=0; shift ;;
            --groups-after)   _g_groups_after=1; shift ;;
            -v|--verbose)     _g_verbose=1;   shift ;;
            --help|-h)
                zdot_info "zdot hook graph — pstree-style dependency tree"
                zdot_info ""
                zdot_info "  --depends <name>     What a hook requires (recursive)"
                zdot_info "  --uses <name>        What depends on a hook (recursive)"
                zdot_info "  --all                Full graph"
                zdot_info ""
                zdot_info "  --ascii              ASCII glyphs only"
                zdot_info "  --max-depth N        Cap recursion depth"
                zdot_info "  --show-internal      Include synthetic group hooks"
                zdot_info "  --groups-inline      Expand each group at first use (default)"
                zdot_info "  --groups-after       Keep groups as atoms; expand them in a"
                zdot_info "                       'Group contents' section afterwards"
                zdot_info "  -v, --verbose        Show label and function name together"
                zdot_info ""
                zdot_info "  Solid connectors are hard --requires edges. Dim connectors with"
                zdot_info "  an arrow are soft ordering: ◂ = --after (runs after), ▸ = --before"
                zdot_info "  (runs before); absent if the target isn't registered."
                return 0
                ;;
            *)
                zdot_error "zdot hook graph: unknown option '$1'"
                zdot_info "  usage: zdot hook graph --depends <name> | --uses <name> | --all"
                return 1
                ;;
        esac
    done

    if [[ -z "$mode" ]]; then
        zdot_error "zdot hook graph: no mode specified"
        zdot_info "  usage: zdot hook graph --depends <name> | --uses <name> | --all"
        return 1
    fi

    # ── glyph table ───────────────────────────────────────────────────────────
    # Two character widths matter for alignment:
    #   _G_TEE  (inline first-child connector after parent label) — 3 chars
    #   _G_BRANCH / _G_LAST (sibling connector under parent)      — 2 chars
    #   _G_VERT / _G_BLANK  (continuation under sibling connector) — 2 chars
    #   _G_DASH (chain-collapse connector "A─B")                  — 3 chars
    # See the column-math comment near _zdot_g_render for why.
    local _G_TEE _G_BRANCH _G_LAST _G_VERT _G_BLANK _G_DASH _G_UP _G_ELLIPSIS
    # Soft-ordering (--after / --before) edges render dimmed with a 1-cell
    # direction arrow in place of one branch dash. The skeleton char (├ / └)
    # stays box-drawing so a soft sibling's column still lands under its parent
    # bar; only the arrow carries direction:
    #   after  → ◂  ("parent runs AFTER this node" — the node is a soft predecessor)
    #   before → ▸  ("parent runs BEFORE this node" — the node is a soft successor)
    # Arrows live only in prefix connectors (never in width-measured heads), and
    # soft children are kept out of the inline first-child slot, so an unexpected
    # arrow cell-width can't cascade into the overprint the hourglass caused.
    local _G_DIM _G_DIMOFF _G_SBRANCH _G_SLAST _G_AFTER_ARROW _G_BEFORE_ARROW _G_VBAR
    if (( _g_ascii )); then
        _G_TEE='-+-'
        _G_BRANCH='|-'
        _G_LAST='`-'
        _G_VERT='| '
        _G_BLANK='  '
        _G_DASH='---'
        _G_UP='^'
        _G_ELLIPSIS='...'
        _G_DIM='%F{8}'; _G_DIMOFF='%f'
        _G_SBRANCH='|'; _G_SLAST='`'; _G_VBAR='|'
        _G_AFTER_ARROW='<'; _G_BEFORE_ARROW='>'
    else
        _G_TEE='─┬─'
        _G_BRANCH='├─'
        _G_LAST='└─'
        _G_VERT='│ '
        _G_BLANK='  '
        _G_DASH='───'
        _G_UP='↑'
        _G_ELLIPSIS='…'
        _G_DIM='%F{8}'; _G_DIMOFF='%f'
        _G_SBRANCH='├'; _G_SLAST='╰'; _G_VBAR='│'
        _G_AFTER_ARROW='◂'; _G_BEFORE_ARROW='▸'
    fi

    # ── helpers ───────────────────────────────────────────────────────────────

    # Resolve a user-supplied name (label or function name) to a hook_id in REPLY.
    function _zdot_g_resolve_id() {
        local name="$1"
        REPLY=""
        if [[ -n "${_ZDOT_HOOK_BY_NAME[$name]}" ]]; then
            REPLY="${_ZDOT_HOOK_BY_NAME[$name]}"
            return 0
        fi
        local hid
        for hid in ${(k)_ZDOT_HOOKS}; do
            if [[ "${_ZDOT_HOOKS[$hid]}" == "$name" ]]; then
                REPLY="$hid"
                return 0
            fi
        done
        return 1
    }

    # ── group contraction ──────────────────────────────────────────────────────
    # Default view collapses each group into a single [group:G] node: its real
    # members AND its begin/end barrier hooks all canonicalise to "group:G", and the
    # intra-group edges between them drop out. --show-internal disables this (the raw
    # barrier + per-member graph is kept). _zdot_g_canon_map is hook_id -> "group:G".
    typeset -gA _zdot_g_canon_map=()
    function _zdot_g_build_canon_map() {
        _zdot_g_canon_map=()
        local g hid label
        for g in ${(k)_ZDOT_GROUP_MEMBERS}; do
            for hid in ${=_ZDOT_GROUP_MEMBERS[$g]}; do
                [[ -n "${_zdot_g_canon_map[$hid]:-}" ]] || _zdot_g_canon_map[$hid]="group:$g"
            done
        done
        for hid in ${(k)_ZDOT_HOOKS}; do
            label="${_ZDOT_HOOK_NAMES[$hid]:-}"
            case $label in
                group-begin:*|group-end:*) _zdot_g_canon_map[$hid]="group:${label#*:}" ;;
            esac
        done
    }
    # Map a hook_id to its display node: [group:G] if it belongs to a group, else itself.
    function _zdot_g_canon() { REPLY="${_zdot_g_canon_map[$1]:-$1}"; }

    # Synthetic group scaffolding has labels like "group-begin:<group>" or
    # "group-end:<group>" — see core/hooks.zsh:1038-1051.
    function _zdot_g_is_internal() {
        local hid="$1"
        local label="${_ZDOT_HOOK_NAMES[$hid]:-}"
        [[ "$label" == group-begin:* || "$label" == group-end:* ]]
    }

    # Display name for a hook_id (label preferred; func when label==func or missing).
    # Verbose mode shows both.
    function _zdot_g_display_name() {
        local hid="$1"
        if [[ "$hid" == group:* ]]; then
            # [group:…] (ASCII) — matches the chip form used by `zdot hook plan`.
            print -r -- "%F{magenta}[group:${hid#group:}]%f"
            return
        fi
        local label="${_ZDOT_HOOK_NAMES[$hid]:-}"
        local func="${_ZDOT_HOOKS[$hid]:-$hid}"
        local out
        if (( _g_verbose )) && [[ -n "$label" && "$label" != "$func" ]]; then
            if (( _g_ascii )); then
                out="${label}  <${func}>"
            else
                out="${label}  ⟨${func}⟩"
            fi
        elif [[ -n "$label" && "$label" != "$func" ]]; then
            out="$label"
        else
            out="$func"
        fi
        # Deferral annotation — same marks as `zdot hook list`/`plan`:
        # magenta [ deferred] for --deferred hooks, yellow
        # [ deferred: forced] for hooks promoted into the deferred plan by
        # their dependencies. ASCII mode keeps the words, drops the glyphs.
        local _name_mark="" _deferred_mark="" _noquiet_mark="" _status_mark=""
        _zdot_hook_display_marks "$hid" "$func"
        (( _g_ascii )) && _deferred_mark="${_deferred_mark//[] /}"
        out+="$_deferred_mark"
        print -r -- "$out"
    }

    # Visible width of a head string for the pstree column math. Two things
    # would otherwise throw it off, so both are corrected here:
    #   1. %F{colour}…%f escapes — stripped (they have zero on-screen width).
    #   2. Wide glyphs — the Nerd-Font deferral hourglasses (U+F251/U+F250) are
    #      icon glyphs that render TWO cells in many fonts, yet zsh's wcwidth (a
    #      plain ${#s}) counts one. Rather than hard-code "= 2", we MEASURE the
    #      real width once via _zdot_g_cellwidth and add the surplus per glyph.
    # Uncorrected, every deferred mark in a (chain-collapsed) head shifts the
    # children one column left of their ┬ until sibling bars overprint.
    function _zdot_g_vwidth() {
        setopt localoptions extendedglob   # ## closure below needs it
        local s=${1//\%F\{[^\}]##\}/}   # drop every %F{colour}
        s=${s//\%f/}                     # …and its %f reset
        local total=${#s} g bare n
        for g in $'' $''; do
            bare=${s//$g/}
            n=$(( ${#s} - ${#bare} ))    # occurrences (glyph is 1 codepoint each)
            (( n )) || continue
            _zdot_g_cellwidth "$g"
            (( total += n * (REPLY - 1) ))
        done
        REPLY=$total
    }

    # Measure a glyph's true terminal cell width by asking the terminal where the
    # cursor lands after we print it (Cursor Position Report: emit, send ESC[6n,
    # read back ESC[row;colR — the column delta is the rendered width). The probe
    # line is wiped immediately, results are memoised, and we fall back to the
    # zsh char count when stdout is not a tty (e.g. piped to a file, where on-
    # screen alignment is moot anyway). This adapts to the font instead of
    # assuming a fixed width for the icon glyphs.
    typeset -gA _zdot_g_cellw=()
    function _zdot_g_cellwidth() {
        local glyph="$1"
        [[ -n "${_zdot_g_cellw[$glyph]:-}" ]] && { REPLY=${_zdot_g_cellw[$glyph]}; return; }
        local w=${#glyph} _stty resp
        if [[ -t 1 && -w /dev/tty && -r /dev/tty ]]; then
            _stty=$(stty -g </dev/tty 2>/dev/null)
            if [[ -n "$_stty" ]]; then
                stty raw -echo min 0 time 2 </dev/tty 2>/dev/null
                print -n -- $'\r'"${glyph}"$'\e[6n' >/dev/tty
                resp=""
                read -rs -d R -t 1 resp </dev/tty 2>/dev/null
                print -n -- $'\e[2K\r' >/dev/tty
                stty "$_stty" </dev/tty 2>/dev/null
                local col=${resp##*;}
                [[ "$col" == <-> ]] && w=$(( col - 1 ))
            fi
        fi
        _zdot_g_cellw[$glyph]=$w
        REPLY=$w
    }

    # Display for any node, including phase pseudo-nodes. A phase whose
    # provider is deferred (explicitly or by force-deferral) is annotated —
    # anything waiting on it lands after the first prompt.
    function _zdot_g_display_for_child() {
        local x="$1"
        if [[ "$x" == phase:* ]]; then
            local _ph="${x#phase:}" _pmark="" _k _phid
            for _k in ${(k)_ZDOT_PHASE_PROVIDERS_BY_CONTEXT}; do
                [[ "$_k" == *:"$_ph" ]] || continue
                _phid="${_ZDOT_PHASE_PROVIDERS_BY_CONTEXT[$_k]}"
                if [[ ${_ZDOT_DEFERRED_HOOKS[(Ie)$_phid]} -gt 0 || \
                      ${_ZDOT_EXECUTION_PLAN_DEFERRED[(Ie)$_phid]} -gt 0 ]]; then
                    _pmark=" %F{yellow}[ deferred]%f"
                    break
                fi
            done
            (( _g_ascii )) && _pmark="${_pmark//[] /}"
            print -r -- "[phase: ${_ph}]${_pmark}"
        else
            _zdot_g_display_name "$x"
        fi
    }

    # Cache the set of contexts in which any hook is registered, for phase lookups.
    function _zdot_g_all_contexts() {
        local -a ctxs=()
        local hid c
        for hid in ${(k)_ZDOT_HOOKS}; do
            for c in ${=_ZDOT_HOOK_CONTEXTS[$hid]}; do
                [[ -z "${ctxs[(r)$c]}" ]] && ctxs+=("$c")
            done
        done
        print -r -- "${ctxs[@]}"
    }
    local -a _all_ctx
    _all_ctx=( ${=$(_zdot_g_all_contexts)} )

    # Measure every wide glyph once, up front, so the cursor-position probes in
    # _zdot_g_cellwidth never interleave with rendered output. After this the
    # widths are memoised and lookups during rendering do no terminal I/O.
    _zdot_g_cellwidth $''   # deferral hourglass (by design)
    _zdot_g_cellwidth $''   # deferral hourglass (forced)
    if (( ! _g_ascii )); then
        _zdot_g_cellwidth "$_G_AFTER_ARROW"
        _zdot_g_cellwidth "$_G_BEFORE_ARROW"
    fi

    # Resolve a phase name to its provider hook_id via context lookup; first match wins.
    function _zdot_g_provider_for_phase() {
        local phase="$1"
        REPLY=""
        local ctx
        for ctx in "${_all_ctx[@]}"; do
            local key="${ctx}:${phase}"
            if [[ -n "${_ZDOT_PHASE_PROVIDERS_BY_CONTEXT[$key]}" ]]; then
                REPLY="${_ZDOT_PHASE_PROVIDERS_BY_CONTEXT[$key]}"
                return 0
            fi
        done
        return 1
    }

    # Reverse map: hook_id -> space-separated list of hook_ids that depend on it.
    # Populates global _zdot_g_rev_map (declared by caller).
    function _zdot_g_build_reverse_map() {
        local hid phase provider_id
        for hid in ${(k)_ZDOT_HOOKS}; do
            local requires="${_ZDOT_HOOK_REQUIRES[$hid]:-}"
            [[ -z "$requires" ]] && continue
            for phase in ${=requires}; do
                # Skip finally/pre-defer "ordering injection" edges: every hook
                # provides a _group_member_<G>_<self> token purely so G's begin
                # barrier can sort last. Those aren't real membership (the hook is
                # not in _ZDOT_GROUP_MEMBERS[G]) and would hang G's whole subtree
                # under EVERY hook. Real membership tokens (--group G) are kept, so
                # genuine group structure still renders. (--show-internal keeps all.)
                # Suppress finally/pre-defer "ordering injection" edges: every hook
                # provides a _group_member_<G>_<self> token only so G's begin barrier
                # sorts last. Those aren't real membership, so dropping them keeps the
                # gather-all groups from smearing under every hook — they instead
                # surface as a single root node (a universal sink). Real membership
                # tokens fall through and get contracted into the group node below.
                if (( ! _g_show_internal )) && [[ $phase == _group_member_*_hook_<-> ]]; then
                    local _g=${phase#_group_member_}; _g=${_g%_hook_<->}
                    local _m="hook_${phase##*_hook_}"
                    [[ " ${_ZDOT_GROUP_MEMBERS[$_g]:-} " == *" $_m "* ]] || continue
                fi
                _zdot_g_provider_for_phase "$phase"
                provider_id="$REPLY"
                [[ -z "$provider_id" ]] && continue
                # Contract groups: map members + begin/end barriers to their [group:G]
                # node, and drop the resulting intra-group self-edges. (No-op under
                # --show-internal, which keeps the raw barrier/member graph.)
                local _cnode="$hid" _pnode="$provider_id"
                if (( ! _g_show_internal )); then
                    _zdot_g_canon "$hid";         _cnode="$REPLY"
                    _zdot_g_canon "$provider_id"; _pnode="$REPLY"
                fi
                [[ "$_pnode" == "$_cnode" ]] && continue
                # Record the hard edge (provider → dependent) so soft --after /
                # --before edges that merely restate an existing hard dependency
                # are not drawn as soft (hard wins — see _zdot_g_build_soft_edges).
                _zdot_g_hard_edge[${_pnode}::${_cnode}]=1
                if [[ -z "${_zdot_g_rev_map[$_pnode]}" ]]; then
                    _zdot_g_rev_map[$_pnode]="$_cnode"
                elif [[ " ${_zdot_g_rev_map[$_pnode]} " != *" $_cnode "* ]]; then
                    _zdot_g_rev_map[$_pnode]+=" $_cnode"
                fi
            done
        done
    }

    # Soft-ordering edges from --after / --before, resolved + group-contracted
    # into the same node space as the hard graph. Both reduce to a directed
    # "from runs before to" edge (the planner's convention, core/hooks.zsh):
    #   B --after  X   →  edge  resolve(X) → B   (X is a soft predecessor of B)
    #   B --before X   →  edge  B → resolve(X)   (X is a soft successor   of B)
    # Targets resolve as a phase provider first (covers --after-tool's tool:<t>),
    # then as a hook name — exactly as the planner resolves them. Absent targets
    # are a silent no-op, like the planner. Populates:
    #   _zdot_g_soft_kind[from::to] = after|before   (kind, for the connector)
    #   _zdot_g_soft_pre[to]       += from           (soft predecessors, --depends)
    # and folds each edge into _zdot_g_rev_map so the --uses / --all direction and
    # root computation see soft dependents too.
    function _zdot_g_build_soft_edges() {
        local b kind reg t x from to _f _to2
        for b in ${(k)_ZDOT_HOOKS}; do
            for kind in after before; do
                if [[ "$kind" == after ]]; then
                    reg="${_ZDOT_HOOK_AFTER[$b]:-}"
                else
                    reg="${_ZDOT_HOOK_BEFORE[$b]:-}"
                fi
                [[ -z "$reg" ]] && continue
                for t in ${=reg}; do
                    local -a resolved=()
                    if _zdot_g_provider_for_phase "$t"; then
                        resolved+=("$REPLY")
                    elif [[ -n "${_ZDOT_HOOK_BY_NAME[$t]:-}" ]]; then
                        resolved+=("${_ZDOT_HOOK_BY_NAME[$t]}")
                    fi
                    for x in ${(u)resolved}; do
                        if [[ "$kind" == after ]]; then from="$x"; to="$b"; else from="$b"; to="$x"; fi
                        _f="$from"; _to2="$to"
                        if (( ! _g_show_internal )); then
                            _zdot_g_canon "$from"; _f="$REPLY"
                            _zdot_g_canon "$to";   _to2="$REPLY"
                        fi
                        [[ "$_f" == "$_to2" ]] && continue
                        # Hard dependency already covers this pair → keep it hard.
                        [[ -n "${_zdot_g_hard_edge[${_f}::${_to2}]:-}" ]] && continue
                        # First declaration wins (a pair is at most one soft kind).
                        [[ -n "${_zdot_g_soft_kind[${_f}::${_to2}]:-}" ]] && continue
                        _zdot_g_soft_kind[${_f}::${_to2}]="$kind"
                        # soft predecessor index for --depends
                        if [[ " ${_zdot_g_soft_pre[$_to2]:-} " != *" $_f "* ]]; then
                            _zdot_g_soft_pre[$_to2]+=" $_f"
                        fi
                        # fold into reverse map for --uses / --all
                        if [[ -z "${_zdot_g_rev_map[$_f]:-}" ]]; then
                            _zdot_g_rev_map[$_f]="$_to2"
                        elif [[ " ${_zdot_g_rev_map[$_f]} " != *" $_to2 "* ]]; then
                            _zdot_g_rev_map[$_f]+=" $_to2"
                        fi
                    done
                done
            done
        done
    }

    # Edge kind between a displayed parent and child: hard | after | before.
    # The soft map is keyed from→to (from runs before to); the lookup orientation
    # depends on which way the current view walks the graph.
    function _zdot_g_edge_kind() {   # $1 parent, $2 child
        if [[ "$_zdot_g_dir" == depends ]]; then
            REPLY="${_zdot_g_soft_kind[${2}::${1}]:-hard}"   # child is a predecessor of parent
        else
            REPLY="${_zdot_g_soft_kind[${1}::${2}]:-hard}"   # child depends on parent
        fi
    }

    # ── child enumeration ─────────────────────────────────────────────────────
    # Direction toggle. "depends" → children = requirements (downward through requires).
    # "uses" → children = dependents (upward via reverse map).
    local _zdot_g_dir=""

    # Sort an array of node-ids by display name. Sets REPLY to newline-joined ids.
    function _zdot_g_sort_by_display() {
        local -a paired=()
        local x d label func
        for x in "$@"; do
            if [[ "$x" == phase:* ]]; then
                d="[phase: ${x#phase:}]"
            elif [[ "$x" == group:* ]]; then
                d="[group:${x#group:}]"
            else
                label="${_ZDOT_HOOK_NAMES[$x]:-}"
                func="${_ZDOT_HOOKS[$x]:-$x}"
                if [[ -n "$label" && "$label" != "$func" ]]; then
                    d="$label"
                else
                    d="$func"
                fi
            fi
            paired+=("${d}"$'\t'"${x}")
        done
        paired=( ${(o)paired} )
        local -a result=()
        for x in "${paired[@]}"; do
            result+=("${x##*$'\t'}")
        done
        REPLY="${(F)result}"
    }

    # Raw (unfiltered, unsorted) children of node $1 in the current direction.
    # Returns newline-joined ids in REPLY.
    function _zdot_g_raw_children() {
        local hid="$1"
        local -a out=()
        # Group pseudo-node: contents are the group's real members; in --uses we
        # also hang its external dependents (consumers) off it.
        if [[ "$hid" == group:* ]]; then
            out=()
            # In --groups-after the group is an atom in the main tree: its members
            # are suppressed (listed in the "Group contents" section instead).
            # External dependents / soft predecessors still show, to keep the flow.
            if (( ! _g_groups_after )); then
                out=( ${=_ZDOT_GROUP_MEMBERS[${hid#group:}]:-} )
            fi
            [[ "$_zdot_g_dir" == "uses" ]] && out+=( ${=_zdot_g_rev_map[$hid]:-} )
            [[ "$_zdot_g_dir" == "depends" ]] && out+=( ${=_zdot_g_soft_pre[$hid]:-} )
            REPLY="${(F)out}"
            return
        fi
        local _hn="$hid"
        (( ! _g_show_internal )) && { _zdot_g_canon "$hid"; _hn="$REPLY"; }
        if [[ "$_zdot_g_dir" == "depends" ]]; then
            local requires="${_ZDOT_HOOK_REQUIRES[$hid]:-}"
            local phase provider _pn
            for phase in ${=requires}; do
                # Drop injection ordering tokens (member token of a non-member); the
                # gather-all begin barrier otherwise lists every hook. See reverse map.
                if (( ! _g_show_internal )) && [[ $phase == _group_member_*_hook_<-> ]]; then
                    local _g=${phase#_group_member_}; _g=${_g%_hook_<->}
                    local _m="hook_${phase##*_hook_}"
                    [[ " ${_ZDOT_GROUP_MEMBERS[$_g]:-} " == *" $_m "* ]] || continue
                fi
                _zdot_g_provider_for_phase "$phase"
                provider="$REPLY"
                if [[ -n "$provider" ]]; then
                    _pn="$provider"
                    (( ! _g_show_internal )) && { _zdot_g_canon "$provider"; _pn="$REPLY"; }
                    [[ "$_pn" == "$_hn" ]] && continue   # drop intra-group self-edge
                    out+=("$_pn")
                else
                    out+=("phase:$phase")
                fi
            done
            # Soft --after / --before predecessors of this node (run before it).
            out+=( ${=_zdot_g_soft_pre[$_hn]:-} )
        else
            local deps="${_zdot_g_rev_map[$hid]:-}"
            out=( ${=deps} )
        fi
        REPLY="${(F)out}"
    }

    # Filtered + sorted children: flatten through internal hooks (unless
    # --show-internal), dedupe, then sort.
    function _zdot_g_filtered_children() {
        local hid="$1"
        _zdot_g_raw_children "$hid"
        local -a worklist=( ${(f)REPLY} )
        # Drop any empty elements that the split may have produced.
        local -a _wl=()
        local _t
        for _t in "${worklist[@]}"; do [[ -n "$_t" ]] && _wl+=("$_t"); done
        worklist=( "${_wl[@]}" )

        local -a flat=()
        local x
        while (( ${#worklist[@]} > 0 )); do
            x="${worklist[1]}"
            shift worklist
            if [[ "$x" == phase:* ]]; then
                flat+=("$x")
            elif (( ! _g_show_internal )) && _zdot_g_is_internal "$x"; then
                _zdot_g_raw_children "$x"
                local -a sub=( ${(f)REPLY} )
                local -a _sl=()
                for _t in "${sub[@]}"; do [[ -n "$_t" ]] && _sl+=("$_t"); done
                worklist=( "${_sl[@]}" "${worklist[@]}" )
            else
                flat+=("$x")
            fi
        done

        # Dedup, preserve first-occurrence order.
        local -A seen_l=()
        local -a uniq=()
        for x in "${flat[@]}"; do
            if [[ -z "${seen_l[$x]:-}" ]]; then
                seen_l[$x]=1
                uniq+=("$x")
            fi
        done

        _zdot_g_sort_by_display "${uniq[@]}"
    }

    # ── renderer ──────────────────────────────────────────────────────────────
    # Column-math reminder for the multi-child case (`parent` has children c1..cN):
    #
    #     pfx1 + head ─┬─ child1
    #     pfxc + pad   ├─ child2
    #     pfxc + pad   └─ child3
    #
    # head_w  = visible width of the head string (label, or chain "A─B─C")
    # pad     = head_w + 1 spaces — puts ├ / └ directly under the ┬ above
    # _G_TEE  = "─┬─" (3 chars)
    # _G_BRANCH/_G_LAST = "├─" / "└─" (2 chars)
    # _G_VERT/_G_BLANK  = "│ " / "  " (2 chars) — continuation under sibling connector
    # After connector, the child's name starts at column head_w + 3 in every case,
    # so child sub-trees line up vertically.

    # _zdot_g_seen is the global DAG dedup set for one rendering pass.
    typeset -gA _zdot_g_seen=()

    function _zdot_g_render() {
        local nid="$1" pfx1="$2" pfxc="$3" depth="$4"

        # Phase pseudo-node: no further structure.
        if [[ "$nid" == phase:* ]]; then
            zdot_info "${pfx1}[phase: ${nid#phase:}] (no provider)"
            return
        fi

        # Already shown elsewhere — back-reference. Checked before the depth
        # cap so that a node we've already rendered in full keeps its "↑"
        # marker even if we re-encounter it past the depth limit.
        if [[ -n "${_zdot_g_seen[$nid]:-}" ]]; then
            local lbl
            lbl="$(_zdot_g_display_name "$nid")"
            zdot_info "${pfx1}${lbl} ${_G_UP}"
            return
        fi

        # Depth cap: print a trailing ellipsis and stop. Don't mark seen —
        # if a higher-up render reaches this node, we want it shown fully.
        if (( _g_max_depth >= 0 && depth >= _g_max_depth )); then
            local lbl
            lbl="$(_zdot_g_display_for_child "$nid")"
            zdot_info "${pfx1}${lbl} ${_G_ELLIPSIS}"
            return
        fi

        _zdot_g_seen[$nid]=1

        # Build head with chain collapse: while node has exactly one child we can
        # follow *via a hard edge*, append " ─── child" and step into the child.
        # Soft (--after/--before) children are never inlined — their dim arrow
        # connector rides only on a vertical branch, so its cell width can't
        # perturb the measured head column math.
        local head cur="$nid"
        head="$(_zdot_g_display_name "$nid")"
        _zdot_g_filtered_children "$cur"
        local -a kids=( ${(f)REPLY} )
        local -a _kl=()
        local _kt
        for _kt in "${kids[@]}"; do [[ -n "$_kt" ]] && _kl+=("$_kt"); done
        kids=( "${_kl[@]}" )

        local chain_depth=$depth
        while (( ${#kids[@]} == 1 )); do
            local only="${kids[1]}"
            [[ "$only" == phase:* ]] && break
            [[ -n "${_zdot_g_seen[$only]:-}" ]] && break
            _zdot_g_edge_kind "$cur" "$only"; [[ "$REPLY" == hard ]] || break
            if (( _g_max_depth >= 0 && chain_depth + 1 >= _g_max_depth )); then
                break
            fi
            head="${head}${_G_DASH}$(_zdot_g_display_name "$only")"
            _zdot_g_seen[$only]=1
            cur="$only"
            _zdot_g_filtered_children "$cur"
            kids=( ${(f)REPLY} )
            _kl=()
            for _kt in "${kids[@]}"; do [[ -n "$_kt" ]] && _kl+=("$_kt"); done
            kids=( "${_kl[@]}" )
            (( chain_depth++ ))
        done

        local n=${#kids[@]}
        if (( n == 0 )); then
            zdot_info "${pfx1}${head}"
            return
        fi

        # Classify each child of `cur` (hard | after | before), then reorder
        # stably so hard edges come first. The inline first-child slot (the ─┬─
        # tee, whose width feeds the column math) is thus always a hard edge;
        # soft children fall to the vertical branches where their dim arrow
        # connector is width-matched against its continuation and so is safe.
        local -a kinds=()
        for _kt in "${kids[@]}"; do _zdot_g_edge_kind "$cur" "$_kt"; kinds+=("$REPLY"); done
        local _i
        local -a _hk=() _hkind=() _sk=() _skind=()
        for (( _i = 1; _i <= n; _i++ )); do
            if [[ "${kinds[$_i]}" == hard ]]; then
                _hk+=("${kids[$_i]}");  _hkind+=("hard")
            else
                _sk+=("${kids[$_i]}");  _skind+=("${kinds[$_i]}")
            fi
        done
        kids=( "${_hk[@]}" "${_sk[@]}" )
        kinds=( "${_hkind[@]}" "${_skind[@]}" )

        _zdot_g_vwidth "$head"; local head_w=$REPLY
        local pad=""
        for (( _i=0; _i < head_w + 1; _i++ )); do pad+=" "; done

        # The first child rides the inline tee only when it's a hard edge.
        local first_inline=0
        [[ "${kinds[1]}" == hard ]] && first_inline=1

        if (( first_inline && n == 1 )); then
            # Chain collapse broke at a hard single child. Render it inline,
            # tagged with why we stopped: phase pseudo-node, back-reference
            # to a previously-seen node, or depth-limit cutoff.
            local only="${kids[1]}"
            if [[ "$only" == phase:* ]]; then
                zdot_info "${pfx1}${head}${_G_DASH}[phase: ${only#phase:}] (no provider)"
            elif [[ -n "${_zdot_g_seen[$only]:-}" ]]; then
                zdot_info "${pfx1}${head}${_G_DASH}$(_zdot_g_display_name "$only") ${_G_UP}"
            else
                zdot_info "${pfx1}${head}${_G_DASH}$(_zdot_g_display_name "$only") ${_G_ELLIPSIS}"
            fi
            return
        fi

        # Lay out children. A hard first child rides inline after the head (tee);
        # otherwise the head stands alone and every child hangs below it.
        local start=1
        if (( first_inline )); then
            _zdot_g_render "${kids[1]}" "${pfx1}${head}${_G_TEE}" "${pfxc}${pad}${_G_VERT}" $((depth + 1))
            start=2
        else
            zdot_info "${pfx1}${head}"
        fi

        # All loop-body locals declared once up front: re-running `local name`
        # (no value) on an already-declared local prints it, which would leak
        # "_corner=├ …" lines between siblings.
        local i conn cont _corner _arrow _aw _vbar _fill _j
        for (( i = start; i <= n; i++ )); do
            if [[ "${kinds[$i]}" == hard ]]; then
                if (( i == n )); then conn="$_G_LAST"; cont="$_G_BLANK"
                else                  conn="$_G_BRANCH"; cont="$_G_VERT"; fi
            else
                # Soft edge: dim corner + direction arrow. Measure the arrow's
                # real cell width and pad the continuation to match, so the
                # child's own subtree stays aligned whatever the terminal does
                # with the arrow glyph (same trick as the hourglass fix).
                if (( i == n )); then _corner="$_G_SLAST"; _vbar=" "
                else                  _corner="$_G_SBRANCH"; _vbar="$_G_VBAR"; fi
                if [[ "${kinds[$i]}" == after ]]; then _arrow="$_G_AFTER_ARROW"
                else                                   _arrow="$_G_BEFORE_ARROW"; fi
                _zdot_g_cellwidth "$_arrow"; _aw=$REPLY
                _fill=""
                for (( _j = 0; _j < _aw; _j++ )); do _fill+=" "; done
                conn="${_G_DIM}${_corner}${_arrow}${_G_DIMOFF}"
                cont="${_vbar}${_fill}"
            fi
            _zdot_g_render "${kids[$i]}" "${pfxc}${pad}${conn}" "${pfxc}${pad}${cont}" $((depth + 1))
        done
    }

    # ── --groups-after appendix ───────────────────────────────────────────────
    # A "Group contents" section listing the direct members of each group that
    # the just-drawn main tree referenced (read from _zdot_g_seen). This is a
    # flat membership listing — a member's own subtree belongs to the main flow
    # (or `--depends <member>`), so we deliberately do not recurse here; that
    # keeps the section a predictable, scannable definition of each group rather
    # than a second deep graph in a possibly-opposite direction.
    function _zdot_g_render_group_defs() {
        local -a _seed=()
        local _k
        for _k in ${(k)_zdot_g_seen}; do
            [[ "$_k" == group:* ]] && _seed+=("${_k#group:}")
        done
        (( ${#_seed} )) || return 0
        zdot_info ""
        zdot_info "Group contents:"
        # All loop-body locals declared once up front — re-running `local name`
        # (no value) inside the loop would print "name=value" between entries.
        local _G _gd _m _i _w _pad _t _n
        local -a _mem _vis _vl
        for _G in ${(o)_seed}; do
            _mem=( ${=_ZDOT_GROUP_MEMBERS[$_G]:-} )
            _vis=()
            for _m in "${_mem[@]}"; do
                (( ! _g_show_internal )) && _zdot_g_is_internal "$_m" && continue
                _vis+=("$_m")
            done
            _zdot_g_sort_by_display "${_vis[@]}"
            _vis=( ${(f)REPLY} )
            _vl=()
            for _t in "${_vis[@]}"; do [[ -n "$_t" ]] && _vl+=("$_t"); done
            _vis=( "${_vl[@]}" )

            _gd="$(_zdot_g_display_name "group:$_G")"
            _n=${#_vis}
            if (( _n == 0 )); then
                zdot_info "  ${_gd}"
                continue
            fi
            if (( _n == 1 )); then
                zdot_info "  ${_gd}${_G_DASH}$(_zdot_g_display_name "${_vis[1]}")"
                continue
            fi
            _zdot_g_vwidth "$_gd"; _w=$REPLY
            _pad=""
            for (( _i = 0; _i < _w + 1; _i++ )); do _pad+=" "; done
            zdot_info "  ${_gd}${_G_TEE}$(_zdot_g_display_name "${_vis[1]}")"
            for (( _i = 2; _i < _n; _i++ )); do
                zdot_info "  ${_pad}${_G_BRANCH}$(_zdot_g_display_name "${_vis[$_i]}")"
            done
            zdot_info "  ${_pad}${_G_LAST}$(_zdot_g_display_name "${_vis[$_n]}")"
        done
    }

    # ── mode: --depends ──────────────────────────────────────────────────────
    if [[ "$mode" == "depends" ]]; then
        if [[ -z "$target_name" ]]; then
            zdot_error "zdot hook graph --depends: requires a hook name"
            return 1
        fi
        _zdot_g_resolve_id "$target_name"
        local root_id="$REPLY"
        if [[ -z "$root_id" ]]; then
            zdot_error "zdot hook graph --depends: no hook found for '${target_name}'"
            return 1
        fi
        _zdot_g_dir="depends"
        (( _g_show_internal )) || { _zdot_g_build_canon_map; _zdot_g_canon "$root_id"; root_id="$REPLY"; }
        # Soft --after/--before edges need the hard-edge set (built by the reverse
        # map) to know which pairs are already hard, and feed _zdot_g_soft_pre.
        typeset -gA _zdot_g_rev_map=() _zdot_g_hard_edge=() _zdot_g_soft_kind=() _zdot_g_soft_pre=()
        _zdot_g_build_reverse_map
        _zdot_g_build_soft_edges
        _zdot_g_seen=()
        _zdot_g_render "$root_id" "" "" 0
        (( _g_groups_after )) && _zdot_g_render_group_defs
        _zdot_g_seen=()
        _zdot_g_rev_map=()
        return 0
    fi

    # ── modes that need the reverse map ──────────────────────────────────────
    # Canon map must exist before the reverse map (which contracts via it).
    (( _g_show_internal )) || _zdot_g_build_canon_map
    typeset -gA _zdot_g_rev_map=() _zdot_g_hard_edge=() _zdot_g_soft_kind=() _zdot_g_soft_pre=()
    _zdot_g_build_reverse_map
    # Fold soft --after/--before edges into the reverse map so --uses / --all and
    # the root computation account for soft dependents too.
    _zdot_g_build_soft_edges

    if [[ "$mode" == "uses" ]]; then
        if [[ -z "$target_name" ]]; then
            zdot_error "zdot hook graph --uses: requires a hook name"
            _zdot_g_rev_map=()
            return 1
        fi
        _zdot_g_resolve_id "$target_name"
        local root_id="$REPLY"
        if [[ -z "$root_id" ]]; then
            zdot_error "zdot hook graph --uses: no hook found for '${target_name}'"
            _zdot_g_rev_map=()
            return 1
        fi
        _zdot_g_dir="uses"
        (( _g_show_internal )) || { _zdot_g_canon "$root_id"; root_id="$REPLY"; }
        _zdot_g_seen=()
        _zdot_g_render "$root_id" "" "" 0
        (( _g_groups_after )) && _zdot_g_render_group_defs
        _zdot_g_seen=()
        _zdot_g_rev_map=()
        return 0
    fi

    # ── mode: --all ──────────────────────────────────────────────────────────
    # Roots = hooks no other hook depends on (top of the --uses direction).
    # With --show-internal off, expand internal roots into their non-internal
    # descendants, and keep only those that no non-internal hook depends on
    # (so we don't list a hook as a root when it's actually a descendant of a
    # visible hook).
    local -A is_dep=()
    local hid d
    for hid in ${(k)_zdot_g_rev_map}; do
        for d in ${=_zdot_g_rev_map[$hid]}; do
            is_dep[$d]=1
        done
    done

    # Roots = nodes nothing depends on. Default view works on the contracted node
    # set (each hook mapped to its [group:G] box, deduped), so members and barriers
    # fold into their group rather than appearing as spurious standalone roots.
    # --show-internal uses the raw hook set.
    local -a final_roots=()
    local -A _seen_node=()
    local _n
    for hid in ${(k)_ZDOT_HOOKS}; do
        if (( _g_show_internal )); then
            _n="$hid"
        else
            _zdot_g_canon "$hid"; _n="$REPLY"
        fi
        [[ -n "${_seen_node[$_n]:-}" ]] && continue
        _seen_node[$_n]=1
        [[ -n "${is_dep[$_n]:-}" ]] && continue
        final_roots+=("$_n")
    done

    if (( ${#final_roots[@]} == 0 )); then
        zdot_info "(no hooks registered)"
        _zdot_g_rev_map=()
        return 0
    fi

    _zdot_g_sort_by_display "${final_roots[@]}"
    final_roots=( ${(f)REPLY} )
    local -a _fr=()
    local _ft
    for _ft in "${final_roots[@]}"; do [[ -n "$_ft" ]] && _fr+=("$_ft"); done
    final_roots=( "${_fr[@]}" )

    if (( _g_show_internal )); then
        zdot_info "Hook dependency graph (─→ what depends on each root; internals shown):"
    else
        zdot_info "Hook dependency graph (─→ what depends on each root):"
    fi

    _zdot_g_dir="uses"
    _zdot_g_seen=()
    local r
    for r in "${final_roots[@]}"; do
        _zdot_g_render "$r" "" "" 0
    done
    (( _g_groups_after )) && _zdot_g_render_group_defs
    _zdot_g_seen=()
    _zdot_g_rev_map=()
    return 0
}
