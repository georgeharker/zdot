#!/usr/bin/env zsh
# Show a pstree-style dependency-tree graph for the zdot hook system.
#
# Usage:
#   zdot_hooks_graph --depends <name>      Tree of what <name> requires
#   zdot_hooks_graph --uses    <name>      Tree of what depends on <name>
#   zdot_hooks_graph --all                 Full graph (roots have no dependents)
#
# Layout options:
#   --ascii              Use ASCII glyphs (|-, `-, |) instead of Unicode box-drawing
#   --max-depth N        Cap recursion depth (default: unlimited)
#   --show-internal      Show synthetic group-begin / group-end scaffolding hooks
#   -v, --verbose        Show "label  <func>" instead of just the user-facing label
#
# Output style:
#   - Siblings sorted by display name (deterministic)
#   - DAG nodes printed once; repeat occurrences shown as "name ↑"
#   - Single-child chains collapse onto one line:  A ─── B ─── C
#   - Multiple children laid out pstree-style with parent-width alignment:
#         parent─┬─child1
#                ├─child2
#                └─child3

function zdot_hooks_graph() {

    # ── argument parsing ──────────────────────────────────────────────────────

    local mode="" target_name=""
    local _g_ascii=0 _g_max_depth=-1 _g_show_internal=0 _g_verbose=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --depends)        mode="depends"; target_name="$2"; shift 2 ;;
            --uses)           mode="uses";    target_name="$2"; shift 2 ;;
            --all)            mode="all";     shift ;;
            --ascii)          _g_ascii=1;     shift ;;
            --max-depth)      _g_max_depth="$2"; shift 2 ;;
            --show-internal)  _g_show_internal=1; shift ;;
            -v|--verbose)     _g_verbose=1;   shift ;;
            --help|-h)
                zdot_info "zdot hook graph — pstree-style dependency tree"
                zdot_info ""
                zdot_info "  --depends <name>     What a hook requires (recursive)"
                zdot_info "  --uses <name>        What depends on a hook (recursive)"
                zdot_info "  --all                Full graph"
                zdot_info ""
                zdot_info "  --ascii              ASCII glyphs only"
                zdot_info "  --max-depth N        Cap recursion depth"
                zdot_info "  --show-internal      Include synthetic group hooks"
                zdot_info "  -v, --verbose        Show label and function name together"
                return 0
                ;;
            *)
                zdot_error "zdot hook graph: unknown option '$1'"
                zdot_info "  usage: zdot hook graph --depends <name> | --uses <name> | --all"
                return 1
                ;;
        esac
    done

    if [[ -z "$mode" ]]; then
        zdot_error "zdot hook graph: no mode specified"
        zdot_info "  usage: zdot hook graph --depends <name> | --uses <name> | --all"
        return 1
    fi

    # ── glyph table ───────────────────────────────────────────────────────────
    # Two character widths matter for alignment:
    #   _G_TEE  (inline first-child connector after parent label) — 3 chars
    #   _G_BRANCH / _G_LAST (sibling connector under parent)      — 2 chars
    #   _G_VERT / _G_BLANK  (continuation under sibling connector) — 2 chars
    #   _G_DASH (chain-collapse connector "A─B")                  — 3 chars
    # See the column-math comment near _zdot_g_render for why.
    local _G_TEE _G_BRANCH _G_LAST _G_VERT _G_BLANK _G_DASH _G_UP _G_ELLIPSIS
    if (( _g_ascii )); then
        _G_TEE='-+-'
        _G_BRANCH='|-'
        _G_LAST='`-'
        _G_VERT='| '
        _G_BLANK='  '
        _G_DASH='---'
        _G_UP='^'
        _G_ELLIPSIS='...'
    else
        _G_TEE='─┬─'
        _G_BRANCH='├─'
        _G_LAST='└─'
        _G_VERT='│ '
        _G_BLANK='  '
        _G_DASH='───'
        _G_UP='↑'
        _G_ELLIPSIS='…'
    fi

    # ── helpers ───────────────────────────────────────────────────────────────

    # Resolve a user-supplied name (label or function name) to a hook_id in REPLY.
    function _zdot_g_resolve_id() {
        local name="$1"
        REPLY=""
        if [[ -n "${_ZDOT_HOOK_BY_NAME[$name]}" ]]; then
            REPLY="${_ZDOT_HOOK_BY_NAME[$name]}"
            return 0
        fi
        local hid
        for hid in ${(k)_ZDOT_HOOKS}; do
            if [[ "${_ZDOT_HOOKS[$hid]}" == "$name" ]]; then
                REPLY="$hid"
                return 0
            fi
        done
        return 1
    }

    # Synthetic group scaffolding has labels like "group-begin:<group>" or
    # "group-end:<group>" — see core/hooks.zsh:1038-1051.
    function _zdot_g_is_internal() {
        local hid="$1"
        local label="${_ZDOT_HOOK_NAMES[$hid]:-}"
        [[ "$label" == group-begin:* || "$label" == group-end:* ]]
    }

    # Display name for a hook_id (label preferred; func when label==func or missing).
    # Verbose mode shows both.
    function _zdot_g_display_name() {
        local hid="$1"
        local label="${_ZDOT_HOOK_NAMES[$hid]:-}"
        local func="${_ZDOT_HOOKS[$hid]:-$hid}"
        local out
        if (( _g_verbose )) && [[ -n "$label" && "$label" != "$func" ]]; then
            if (( _g_ascii )); then
                out="${label}  <${func}>"
            else
                out="${label}  ⟨${func}⟩"
            fi
        elif [[ -n "$label" && "$label" != "$func" ]]; then
            out="$label"
        else
            out="$func"
        fi
        print -r -- "$out"
    }

    # Display for any node, including phase pseudo-nodes.
    function _zdot_g_display_for_child() {
        local x="$1"
        if [[ "$x" == phase:* ]]; then
            print -r -- "[phase: ${x#phase:}]"
        else
            _zdot_g_display_name "$x"
        fi
    }

    # Cache the set of contexts in which any hook is registered, for phase lookups.
    function _zdot_g_all_contexts() {
        local -a ctxs=()
        local hid c
        for hid in ${(k)_ZDOT_HOOKS}; do
            for c in ${=_ZDOT_HOOK_CONTEXTS[$hid]}; do
                [[ -z "${ctxs[(r)$c]}" ]] && ctxs+=("$c")
            done
        done
        print -r -- "${ctxs[@]}"
    }
    local -a _all_ctx
    _all_ctx=( ${=$(_zdot_g_all_contexts)} )

    # Resolve a phase name to its provider hook_id via context lookup; first match wins.
    function _zdot_g_provider_for_phase() {
        local phase="$1"
        REPLY=""
        local ctx
        for ctx in "${_all_ctx[@]}"; do
            local key="${ctx}:${phase}"
            if [[ -n "${_ZDOT_PHASE_PROVIDERS_BY_CONTEXT[$key]}" ]]; then
                REPLY="${_ZDOT_PHASE_PROVIDERS_BY_CONTEXT[$key]}"
                return 0
            fi
        done
        return 1
    }

    # Reverse map: hook_id -> space-separated list of hook_ids that depend on it.
    # Populates global _zdot_g_rev_map (declared by caller).
    function _zdot_g_build_reverse_map() {
        local hid phase provider_id
        for hid in ${(k)_ZDOT_HOOKS}; do
            local requires="${_ZDOT_HOOK_REQUIRES[$hid]:-}"
            [[ -z "$requires" ]] && continue
            for phase in ${=requires}; do
                _zdot_g_provider_for_phase "$phase"
                provider_id="$REPLY"
                [[ -z "$provider_id" ]] && continue
                [[ "$provider_id" == "$hid" ]] && continue
                if [[ -z "${_zdot_g_rev_map[$provider_id]}" ]]; then
                    _zdot_g_rev_map[$provider_id]="$hid"
                else
                    _zdot_g_rev_map[$provider_id]+=" $hid"
                fi
            done
        done
    }

    # ── child enumeration ─────────────────────────────────────────────────────
    # Direction toggle. "depends" → children = requirements (downward through requires).
    # "uses" → children = dependents (upward via reverse map).
    local _zdot_g_dir=""

    # Sort an array of node-ids by display name. Sets REPLY to newline-joined ids.
    function _zdot_g_sort_by_display() {
        local -a paired=()
        local x d label func
        for x in "$@"; do
            if [[ "$x" == phase:* ]]; then
                d="[phase: ${x#phase:}]"
            else
                label="${_ZDOT_HOOK_NAMES[$x]:-}"
                func="${_ZDOT_HOOKS[$x]:-$x}"
                if [[ -n "$label" && "$label" != "$func" ]]; then
                    d="$label"
                else
                    d="$func"
                fi
            fi
            paired+=("${d}"$'\t'"${x}")
        done
        paired=( ${(o)paired} )
        local -a result=()
        for x in "${paired[@]}"; do
            result+=("${x##*$'\t'}")
        done
        REPLY="${(F)result}"
    }

    # Raw (unfiltered, unsorted) children of node $1 in the current direction.
    # Returns newline-joined ids in REPLY.
    function _zdot_g_raw_children() {
        local hid="$1"
        local -a out=()
        if [[ "$_zdot_g_dir" == "depends" ]]; then
            local requires="${_ZDOT_HOOK_REQUIRES[$hid]:-}"
            local phase provider
            for phase in ${=requires}; do
                _zdot_g_provider_for_phase "$phase"
                provider="$REPLY"
                if [[ -n "$provider" && "$provider" != "$hid" ]]; then
                    out+=("$provider")
                else
                    out+=("phase:$phase")
                fi
            done
        else
            local deps="${_zdot_g_rev_map[$hid]:-}"
            out=( ${=deps} )
        fi
        REPLY="${(F)out}"
    }

    # Filtered + sorted children: flatten through internal hooks (unless
    # --show-internal), dedupe, then sort.
    function _zdot_g_filtered_children() {
        local hid="$1"
        _zdot_g_raw_children "$hid"
        local -a worklist=( ${(f)REPLY} )
        # Drop any empty elements that the split may have produced.
        local -a _wl=()
        local _t
        for _t in "${worklist[@]}"; do [[ -n "$_t" ]] && _wl+=("$_t"); done
        worklist=( "${_wl[@]}" )

        local -a flat=()
        local x
        while (( ${#worklist[@]} > 0 )); do
            x="${worklist[1]}"
            shift worklist
            if [[ "$x" == phase:* ]]; then
                flat+=("$x")
            elif (( ! _g_show_internal )) && _zdot_g_is_internal "$x"; then
                _zdot_g_raw_children "$x"
                local -a sub=( ${(f)REPLY} )
                local -a _sl=()
                for _t in "${sub[@]}"; do [[ -n "$_t" ]] && _sl+=("$_t"); done
                worklist=( "${_sl[@]}" "${worklist[@]}" )
            else
                flat+=("$x")
            fi
        done

        # Dedup, preserve first-occurrence order.
        local -A seen_l=()
        local -a uniq=()
        for x in "${flat[@]}"; do
            if [[ -z "${seen_l[$x]:-}" ]]; then
                seen_l[$x]=1
                uniq+=("$x")
            fi
        done

        _zdot_g_sort_by_display "${uniq[@]}"
    }

    # ── renderer ──────────────────────────────────────────────────────────────
    # Column-math reminder for the multi-child case (`parent` has children c1..cN):
    #
    #     pfx1 + head ─┬─ child1
    #     pfxc + pad   ├─ child2
    #     pfxc + pad   └─ child3
    #
    # head_w  = visible width of the head string (label, or chain "A─B─C")
    # pad     = head_w + 1 spaces — puts ├ / └ directly under the ┬ above
    # _G_TEE  = "─┬─" (3 chars)
    # _G_BRANCH/_G_LAST = "├─" / "└─" (2 chars)
    # _G_VERT/_G_BLANK  = "│ " / "  " (2 chars) — continuation under sibling connector
    # After connector, the child's name starts at column head_w + 3 in every case,
    # so child sub-trees line up vertically.

    # _zdot_g_seen is the global DAG dedup set for one rendering pass.
    typeset -gA _zdot_g_seen=()

    function _zdot_g_render() {
        local nid="$1" pfx1="$2" pfxc="$3" depth="$4"

        # Phase pseudo-node: no further structure.
        if [[ "$nid" == phase:* ]]; then
            zdot_info "${pfx1}[phase: ${nid#phase:}] (no provider)"
            return
        fi

        # Already shown elsewhere — back-reference. Checked before the depth
        # cap so that a node we've already rendered in full keeps its "↑"
        # marker even if we re-encounter it past the depth limit.
        if [[ -n "${_zdot_g_seen[$nid]:-}" ]]; then
            local lbl
            lbl="$(_zdot_g_display_name "$nid")"
            zdot_info "${pfx1}${lbl} ${_G_UP}"
            return
        fi

        # Depth cap: print a trailing ellipsis and stop. Don't mark seen —
        # if a higher-up render reaches this node, we want it shown fully.
        if (( _g_max_depth >= 0 && depth >= _g_max_depth )); then
            local lbl
            lbl="$(_zdot_g_display_for_child "$nid")"
            zdot_info "${pfx1}${lbl} ${_G_ELLIPSIS}"
            return
        fi

        _zdot_g_seen[$nid]=1

        # Build head with chain collapse: while node has exactly one child that we
        # can follow, append " ─── child" to the head and step into the child.
        local head cur="$nid"
        head="$(_zdot_g_display_name "$nid")"
        _zdot_g_filtered_children "$cur"
        local -a kids=( ${(f)REPLY} )
        local -a _kl=()
        local _kt
        for _kt in "${kids[@]}"; do [[ -n "$_kt" ]] && _kl+=("$_kt"); done
        kids=( "${_kl[@]}" )

        local chain_depth=$depth
        while (( ${#kids[@]} == 1 )); do
            local only="${kids[1]}"
            [[ "$only" == phase:* ]] && break
            [[ -n "${_zdot_g_seen[$only]:-}" ]] && break
            if (( _g_max_depth >= 0 && chain_depth + 1 >= _g_max_depth )); then
                break
            fi
            head="${head}${_G_DASH}$(_zdot_g_display_name "$only")"
            _zdot_g_seen[$only]=1
            cur="$only"
            _zdot_g_filtered_children "$cur"
            kids=( ${(f)REPLY} )
            _kl=()
            for _kt in "${kids[@]}"; do [[ -n "$_kt" ]] && _kl+=("$_kt"); done
            kids=( "${_kl[@]}" )
            (( chain_depth++ ))
        done

        local n=${#kids[@]}
        if (( n == 0 )); then
            zdot_info "${pfx1}${head}"
            return
        fi

        local head_w=${#head}
        local pad=""
        local _i
        for (( _i=0; _i < head_w + 1; _i++ )); do pad+=" "; done

        if (( n == 1 )); then
            # Chain collapse broke. Render the remaining child inline,
            # tagged with why we stopped: phase pseudo-node, back-reference
            # to a previously-seen node, or depth-limit cutoff.
            local only="${kids[1]}"
            if [[ "$only" == phase:* ]]; then
                zdot_info "${pfx1}${head}${_G_DASH}[phase: ${only#phase:}] (no provider)"
            elif [[ -n "${_zdot_g_seen[$only]:-}" ]]; then
                local lbl
                lbl="$(_zdot_g_display_name "$only")"
                zdot_info "${pfx1}${head}${_G_DASH}${lbl} ${_G_UP}"
            else
                local lbl
                lbl="$(_zdot_g_display_name "$only")"
                zdot_info "${pfx1}${head}${_G_DASH}${lbl} ${_G_ELLIPSIS}"
            fi
            return
        fi

        # n >= 2: pstree-style first-child inline; remaining siblings beneath.
        local k1_pfx1="${pfx1}${head}${_G_TEE}"
        local k1_pfxc="${pfxc}${pad}${_G_VERT}"
        _zdot_g_render "${kids[1]}" "$k1_pfx1" "$k1_pfxc" $((depth + 1))

        local i
        for (( i = 2; i < n; i++ )); do
            local mp1="${pfxc}${pad}${_G_BRANCH}"
            local mpc="${pfxc}${pad}${_G_VERT}"
            _zdot_g_render "${kids[$i]}" "$mp1" "$mpc" $((depth + 1))
        done

        local lp1="${pfxc}${pad}${_G_LAST}"
        local lpc="${pfxc}${pad}${_G_BLANK}"
        _zdot_g_render "${kids[$n]}" "$lp1" "$lpc" $((depth + 1))
    }

    # ── mode: --depends ──────────────────────────────────────────────────────
    if [[ "$mode" == "depends" ]]; then
        if [[ -z "$target_name" ]]; then
            zdot_error "zdot hook graph --depends: requires a hook name"
            return 1
        fi
        _zdot_g_resolve_id "$target_name"
        local root_id="$REPLY"
        if [[ -z "$root_id" ]]; then
            zdot_error "zdot hook graph --depends: no hook found for '${target_name}'"
            return 1
        fi
        _zdot_g_dir="depends"
        _zdot_g_seen=()
        _zdot_g_render "$root_id" "" "" 0
        _zdot_g_seen=()
        return 0
    fi

    # ── modes that need the reverse map ──────────────────────────────────────
    typeset -gA _zdot_g_rev_map=()
    _zdot_g_build_reverse_map

    if [[ "$mode" == "uses" ]]; then
        if [[ -z "$target_name" ]]; then
            zdot_error "zdot hook graph --uses: requires a hook name"
            _zdot_g_rev_map=()
            return 1
        fi
        _zdot_g_resolve_id "$target_name"
        local root_id="$REPLY"
        if [[ -z "$root_id" ]]; then
            zdot_error "zdot hook graph --uses: no hook found for '${target_name}'"
            _zdot_g_rev_map=()
            return 1
        fi
        _zdot_g_dir="uses"
        _zdot_g_seen=()
        _zdot_g_render "$root_id" "" "" 0
        _zdot_g_seen=()
        _zdot_g_rev_map=()
        return 0
    fi

    # ── mode: --all ──────────────────────────────────────────────────────────
    # Roots = hooks no other hook depends on (top of the --uses direction).
    # With --show-internal off, expand internal roots into their non-internal
    # descendants, and keep only those that no non-internal hook depends on
    # (so we don't list a hook as a root when it's actually a descendant of a
    # visible hook).
    local -A is_dep=()
    local hid d
    for hid in ${(k)_zdot_g_rev_map}; do
        for d in ${=_zdot_g_rev_map[$hid]}; do
            is_dep[$d]=1
        done
    done

    local -a initial_roots=()
    for hid in ${(k)_ZDOT_HOOKS}; do
        [[ -n "${is_dep[$hid]:-}" ]] && continue
        initial_roots+=("$hid")
    done

    local -a final_roots=()
    local -A added=()
    if (( _g_show_internal )); then
        final_roots=( "${initial_roots[@]}" )
    else
        # Build "non-internal is_dep": a hook is a real dependent only if a
        # non-internal hook depends on it.
        local -A ni_is_dep=()
        for hid in ${(k)_zdot_g_rev_map}; do
            _zdot_g_is_internal "$hid" && continue
            for d in ${=_zdot_g_rev_map[$hid]}; do
                ni_is_dep[$d]=1
            done
        done

        local -a worklist=( "${initial_roots[@]}" )
        local w
        while (( ${#worklist[@]} > 0 )); do
            w="${worklist[1]}"
            worklist=( "${worklist[@]:1}" )
            if _zdot_g_is_internal "$w"; then
                local deps_w="${_zdot_g_rev_map[$w]:-}"
                local -a sub=( ${=deps_w} )
                worklist=( "${sub[@]}" "${worklist[@]}" )
            else
                [[ -n "${ni_is_dep[$w]:-}" ]] && continue
                if [[ -z "${added[$w]:-}" ]]; then
                    added[$w]=1
                    final_roots+=("$w")
                fi
            fi
        done
    fi

    if (( ${#final_roots[@]} == 0 )); then
        zdot_info "(no hooks registered)"
        _zdot_g_rev_map=()
        return 0
    fi

    _zdot_g_sort_by_display "${final_roots[@]}"
    final_roots=( ${(f)REPLY} )
    local -a _fr=()
    local _ft
    for _ft in "${final_roots[@]}"; do [[ -n "$_ft" ]] && _fr+=("$_ft"); done
    final_roots=( "${_fr[@]}" )

    if (( _g_show_internal )); then
        zdot_info "Hook dependency graph (─→ what depends on each root; internals shown):"
    else
        zdot_info "Hook dependency graph (─→ what depends on each root):"
    fi

    _zdot_g_dir="uses"
    _zdot_g_seen=()
    local r
    for r in "${final_roots[@]}"; do
        _zdot_g_render "$r" "" "" 0
    done
    _zdot_g_seen=()
    _zdot_g_rev_map=()
    return 0
}
