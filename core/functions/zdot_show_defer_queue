#!/usr/bin/env zsh
# Show the deferred task queue in submission order.
# Populated at runtime when an interactive shell starts; run this after startup.
# Usage: zdot_show_defer_queue
#        zdot hook defer-queue

function zdot_show_defer_queue() {
    if (( _ZDOT_DEFER_COUNTER == 0 )); then
        zdot_info "(no deferred tasks recorded — run an interactive shell first)"
        return 0
    fi

    zdot_report "Deferred Queue (submission order)"
    zdot_info ""

    local i task_num=0 sentinel_num=0
    local prev_hook=""

    for (( i = 1; i <= ${#_ZDOT_DEFER_CMDS[@]}; i++ )); do
        local cmd="${_ZDOT_DEFER_CMDS[$i]}"
        local hook="${_ZDOT_DEFER_HOOKS[$i]}"
        local delay="${_ZDOT_DEFER_DELAYS[$i]}"
        local spec="${_ZDOT_DEFER_SPECS[$i]}"
        local explicit_label="${_ZDOT_DEFER_LABELS[$i]}"

        # ── Sentinel (phase boundary) ────────────────────────────────────
        if [[ "$spec" == "__sentinel__" ]]; then
            (( sentinel_num++ ))
            zdot_info "  %F{240}────── $cmd ──────%f"
            zdot_info ""
            prev_hook=""
            continue
        fi

        (( task_num++ ))

        # ── Hook grouping header ─────────────────────────────────────────
        if [[ "$hook" != "$prev_hook" ]]; then
            if [[ "$hook" != "?" ]]; then
                # Look up the hook's named label if one was set
                local _hook_name=""
                local _hid
                for _hid in ${(k)_ZDOT_HOOKS}; do
                    if [[ "${_ZDOT_HOOKS[$_hid]}" == "$hook" ]]; then
                        _hook_name="${_ZDOT_HOOK_NAMES[$_hid]:-}"
                        break
                    fi
                done
                if [[ -n "$_hook_name" && "$_hook_name" != "$hook" ]]; then
                    zdot_info "  %F{blue}◆ ${hook}%f %F{240}($_hook_name)%f"
                else
                    zdot_info "  %F{blue}◆ ${hook}%f"
                fi
            else
                zdot_info "  %F{240}◆ (outside hook context)%f"
            fi
            prev_hook="$hook"
        fi

        # ── Label: explicit --label > spec name > truncated command ──────
        local label
        if [[ -n "$explicit_label" ]]; then
            label="$explicit_label"
        elif [[ -n "$spec" ]]; then
            label="$spec"
        else
            label="$cmd"
        fi
        # Truncate long labels
        if (( ${#label} > 60 )); then
            label="${label[1,57]}..."
        fi

        # ── Annotations ──────────────────────────────────────────────────
        local -a marks=()
        if (( delay > 0 )); then
            marks+=("%F{yellow}+${delay}s%f")
        fi

        local marks_str=""
        if (( ${#marks} > 0 )); then
            marks_str=" ${(j: :)marks}"
        fi

        # ── Print ────────────────────────────────────────────────────────
        zdot_info "    %F{green}${task_num}.%f ${label}${marks_str}"
    done

    zdot_info ""
    zdot_info "  %F{cyan}${task_num}%f task(s), %F{240}${sentinel_num}%f sentinel(s)"
}
