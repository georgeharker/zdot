#!/usr/bin/env zsh
# Read 1Password vault configuration from zstyle with defaults.
#
# Populates caller-local variables (declare them before calling):
#   op_svc_vault    - vault storing service account credentials
#   op_api_vault    - vault for API keys / tokens
#   op_ssh_vault    - vault for SSH keys
#   op_svc_grants   - array of "vault:permissions" strings for service-account create
#
# zstyle API (set in a secrets-configure group hook):
#   zstyle ':zdot:secrets:op' service-acct-vault 'ServiceAcct'
#   zstyle ':zdot:secrets:op' api-vault          'API'
#   zstyle ':zdot:secrets:op' ssh-vault          'SSHKeys'
#   zstyle ':zdot:secrets:op' service-acct-grants \
#       'API:read_items,write_items' \
#       'SSHKeys:read_items,write_items'

function op_get_vault_config {
    zstyle -s ':zdot:secrets:op' service-acct-vault op_svc_vault \
        || op_svc_vault='ServiceAcct'  # shuck: ignore=C001

    zstyle -s ':zdot:secrets:op' api-vault op_api_vault \
        || op_api_vault='API'

    zstyle -s ':zdot:secrets:op' ssh-vault op_ssh_vault \
        || op_ssh_vault='SSHKeys'

    # Array zstyle: each element is a "vault:permissions" grant string
    if ! zstyle -a ':zdot:secrets:op' service-acct-grants op_svc_grants; then
        op_svc_grants=(  # shuck: ignore=C001
            "${op_api_vault}:read_items,write_items"
            "${op_ssh_vault}:read_items,write_items"
        )
    fi
}
