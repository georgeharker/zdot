#!/usr/bin/env zsh
# Refresh 1Password client secrets (service account)
# In interactive mode: prompts for setup if needed
# In noninteractive mode: only refreshes if already configured
# Sets _ZDOT_OP_ACTIVE=1 on success

function op_refresh {
    local secrets_src_dir secrets_cache
    _op_get_secrets_dirs
    [[ ! -d "${secrets_cache}" ]] && mkdir -p "${secrets_cache}"

    # Get op config
    local -a op_config
    local op_config_dir
    op_config_dir=$(op_get_config_dir)
    op_config=("${(@f)$(op_get_config_args)}")

    # Read vault configuration from zstyle (set in secrets-configure group)
    local op_svc_vault op_api_vault op_ssh_vault
    local -a op_svc_grants
    op_get_vault_config

    # Clear existing token
    typeset +x OP_SERVICE_ACCOUNT_TOKEN
    rm -f "${secrets_cache}/${USER}.op-secrets.zsh"

    # Check if no_op flag is set
    if [[ -f "${op_config_dir}/no_op" ]]; then
        _ZDOT_OP_ACTIVE=0
        return 1
    fi

    # In interactive mode, try to authenticate if not configured
    if [[ $_ZDOT_IS_INTERACTIVE -eq 1 ]]; then
        # Try to authenticate (will prompt if needed)
        if ! op_auth; then
            _ZDOT_OP_ACTIVE=0
            return 1
        fi
    fi

    # In noninteractive mode, check if config exists
    if [[ $_ZDOT_IS_INTERACTIVE -ne 1 ]]; then
        if [[ ! -f "${op_config_dir}/config" ]]; then
            _ZDOT_OP_ACTIVE=0
            return 1
        fi
        # Verify we're signed in (without prompting)
        if ! op whoami ${op_config} &> /dev/null; then
            _ZDOT_OP_ACTIVE=0
            return 1
        fi
    fi

    # If we reach here, authentication is successful
    # Now handle service account setup/refresh

    local host_service_account="$(hostname)-service-account"

    # Interactive mode: offer to create new service account
    if [[ $_ZDOT_IS_INTERACTIVE -eq 1 ]]; then
        echo "Using 1Password to refresh service account"
        
        local new_svc_acct=0
        printf "Create new service-account? [Y/n/c] "
        read -r -k 1 option
        [[ "$option" = $'\n' ]] || echo
        case "$option" in
            [yY$'\n']) new_svc_acct=1 ;;
            [nN]) new_svc_acct=0 ;;
            *)
                echo "You will be asked at next login"
                _ZDOT_OP_ACTIVE=0
                return 1
                ;;
        esac

        if [[ $new_svc_acct -eq 1 ]]; then
            # Build --vault grant flags from config
            local -a grant_flags
            local grant
            for grant in "${op_svc_grants[@]}"; do
                grant_flags+=(--vault "$grant")
            done
            local svc_acct_output=$(op service-account create "$host_service_account" --can-create-vaults \
                                        "${grant_flags[@]}" 2>&1 | grep "export OP_SERVICE_ACCOUNT_TOKEN=")
            if [[ $? -eq 0 ]]; then
                local acct_key=$(eval "$svc_acct_output"; echo $OP_SERVICE_ACCOUNT_TOKEN)
                op item create --vault "$op_svc_vault" \
                                --category "API Credential" \
                                --title "$host_service_account" - \
                                "credential=$acct_key" \
                                "validFrom[string]=" \
                                "expires[string]=" \
                                "host=$(hostname)" > /dev/null
                mkdir -p "${secrets_src_dir}"
                echo "export OP_SERVICE_ACCOUNT_TOKEN=op://${op_svc_vault}/${host_service_account}/credential" > "${secrets_src_dir}/op-secrets.zsh"
            else
                echo "Failed to create service account"
                _ZDOT_OP_ACTIVE=0
                return 1
            fi
        else
            # Offer to choose existing account
            printf "Accounts:\n"
            op item list --vault "$op_svc_vault"
            printf "Choose account name: "
            read -r name
            mkdir -p "${secrets_src_dir}"
            echo "export OP_SERVICE_ACCOUNT_TOKEN=op://${op_svc_vault}/${name}/credential" > "${secrets_src_dir}/op-secrets.zsh"
        fi
    fi

    # Inject secrets (both interactive and noninteractive)
    if [[ -f "${secrets_src_dir}/op-secrets.zsh" ]]; then
        if op ${op_config} inject --force --in-file "${secrets_src_dir}/op-secrets.zsh" --out-file "${secrets_cache}/${USER}.op-secrets.zsh" > /dev/null; then
            # Sign out if in interactive mode
            [[ $_ZDOT_IS_INTERACTIVE -eq 1 ]] && op signout
            _ZDOT_OP_ACTIVE=1
            return 0
        else
            echo "Failed to refresh 1Password service account"
            _ZDOT_OP_ACTIVE=0
            return 1
        fi
    else
        # No source file exists
        _ZDOT_OP_ACTIVE=0
        return 1
    fi
}
