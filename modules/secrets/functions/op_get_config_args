#!/usr/bin/env zsh
# Get 1Password config arguments for op command
# Returns arguments via stdout (one per line for array capture)

function op_get_config_args {
    # If running as sudo, use real user's config
    if [[ -n "${SUDO_USER}" && -n "${REAL_HOME}" ]]; then
        echo "--config"
        echo "${REAL_HOME}/.config/op"
    fi
    # else: no arguments needed (default config)
}
