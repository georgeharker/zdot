#!/usr/bin/env zsh
# Download a file from 1Password vault using the CLI

op_download_file() {
    local vault="$1"
    local item_name="$2"
    local output_dir="$3"
    local prefix="$4"
    
    echo "vault: $vault"
    echo "item_name: $item_name"
    echo "output_dir: $output_dir"
    # Validate inputs
    if [[ -z "$vault" || -z "$item_name" || -z "$output_dir" ]]; then
        echo "Usage: op_download_file <vault> <item_name> <output_dir>" >&2
        return 1
    fi
    
    local item_json=$(op item get "$item_name" --vault="$vault" --format=json 2>/dev/null)
    
    if [[ -z "$item_json" ]]; then
        echo "Error: Item '$item_name' not found in vault '$vault'" >&2
        return 1
    fi
    
    # Extract the original filename
    local filename=$(echo "$item_json" | jq -r '.files[0].name // empty')
    
    if [[ -z "$filename" ]]; then
        echo "Error: No file found in item '$item_name'" >&2
        return 1
    fi
    
    # Create output directory if it doesn't exist
    if [[ -n "$output_dir" && "$output_dir" != "." ]]; then
        mkdir -p "$output_dir"
    fi
    
    # Download the file
    local output_path="${output_dir}/${prefix}${filename}"
    op document get "$item_name" --vault="$vault" --output="$output_path"
}
